#!/usr/bin/env bash
set -euo pipefail

# rhino — CLI for rhino-os v7
# Score = value, not health. Measurement tools: score, taste, eval, status, config

VERSION="7.0.0"
_RHINO_SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$_RHINO_SOURCE" ]]; do
    _RHINO_SOURCE="$(readlink "$_RHINO_SOURCE")"
done
RHINO_DIR="$(cd "$(dirname "$_RHINO_SOURCE")/.." && pwd)"

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# --- Config reader ---
source "$RHINO_DIR/bin/lib/config.sh"

# --- Dependency check (warn, don't block) ---
check_dep() {
    local cmd="$1" needed_for="$2"
    if ! command -v "$cmd" &>/dev/null; then
        echo -e "  ${YELLOW}⚠${NC} ${cmd} not found — needed for ${needed_for}" >&2
        return 1
    fi
    return 0
}

require_dep() {
    local cmd="$1" needed_for="$2"
    if ! command -v "$cmd" &>/dev/null; then
        echo -e "  ${RED}✗${NC} ${cmd} not found — required for ${needed_for}" >&2
        echo -e "  ${DIM}Install ${cmd} and try again.${NC}" >&2
        exit 1
    fi
}

# ============================================================
# SCORE
# ============================================================
cmd_score() {
    "$RHINO_DIR/bin/score.sh" "${@:-.}"
}

# ============================================================
# TASTE
# ============================================================
cmd_taste() {
    require_dep "node" "rhino taste"
    local args=("$@")
    if [[ ${#args[@]} -eq 0 ]]; then
        args=(".")
    fi
    local taste_script="$RHINO_DIR/lens/product/eval/taste.mjs"
    [[ ! -f "$taste_script" ]] && taste_script="$RHINO_DIR/bin/taste.mjs"
    if [[ ! -f "$taste_script" ]]; then
        echo "taste.mjs not found — product lens not installed" >&2
        exit 1
    fi
    node "$taste_script" "${args[@]}"
}

# ============================================================
# STATUS
# ============================================================
cmd_status() {
    echo ""
    echo -e "  ${CYAN}◆${NC} ${BOLD}rhino-os${NC} ${DIM}v${VERSION}${NC}"
    echo ""

    # Claude CLI check
    if command -v claude &>/dev/null; then
        echo -e "  ${GREEN}✓${NC} Claude CLI"
    else
        echo -e "  ${RED}✗${NC} Claude CLI not found"
    fi

    # Mind files
    local mind_count=0
    for f in "$RHINO_DIR"/mind/*.md; do
        [[ -f "$f" ]] && ((mind_count++))
    done
    echo -e "  ${GREEN}✓${NC} Mind: ${mind_count} files loaded"

    # Measurement stack
    local stack_ok=true
    for tool in "$RHINO_DIR/bin/score.sh" "$RHINO_DIR/lens/product/eval/taste.mjs" "$RHINO_DIR/bin/eval.sh"; do
        [[ ! -f "$tool" ]] && stack_ok=false
    done
    if $stack_ok; then
        echo -e "  ${GREEN}✓${NC} Measurement: score, taste, eval"
    else
        echo -e "  ${RED}✗${NC} Measurement stack incomplete"
    fi

    # Last score
    if [[ -f ".claude/cache/score-cache.json" ]] && command -v jq &>/dev/null; then
        local score warnings mode a_count a_pass health_min
        score=$(jq -r '.score // "?"' .claude/cache/score-cache.json 2>/dev/null)
        mode=$(jq -r '.scoring_mode // "empty"' .claude/cache/score-cache.json 2>/dev/null)
        a_count=$(jq -r '.assertion_count // 0' .claude/cache/score-cache.json 2>/dev/null)
        a_pass=$(jq -r '.assertion_pass_count // 0' .claude/cache/score-cache.json 2>/dev/null)
        health_min=$(jq -r '.health_min // "?"' .claude/cache/score-cache.json 2>/dev/null)
        warnings=$(jq -r '.integrity_warnings // [] | join(", ")' .claude/cache/score-cache.json 2>/dev/null)
        echo ""
        if [[ "$mode" == "assertions" ]]; then
            echo -e "  ${DIM}score${NC}    ${BOLD}${score}/100${NC}  ${DIM}${a_pass}/${a_count} assertions · health ${health_min}${NC}"
        elif [[ "$mode" == "onboarding" ]]; then
            echo -e "  ${DIM}score${NC}    ${BOLD}${score}/50${NC}   ${DIM}onboarding · health ${health_min}${NC}"
        else
            echo -e "  ${DIM}score${NC}    ${BOLD}${score}/100${NC}  ${DIM}no value hypothesis · health ${health_min}${NC}"
        fi
        [[ -n "$warnings" ]] && echo -e "           ${YELLOW}⚠ ${warnings}${NC}"
    fi

    # Active plan
    if [[ -f ".claude/plans/active-plan.md" ]]; then
        local total done_count title
        title=$(head -5 .claude/plans/active-plan.md | grep -m1 '^#' | sed 's/^#* *//' || echo "")
        total=$(grep -c '^\- \[' .claude/plans/active-plan.md 2>/dev/null || echo 0)
        done_count=$(grep -c '^\- \[x\]' .claude/plans/active-plan.md 2>/dev/null || echo 0)
        echo -e "  ${DIM}plan${NC}     ${BOLD}${title}${NC} ${DIM}(${done_count}/${total})${NC}"
    fi

    echo ""
}

# ============================================================
# CONFIG
# ============================================================
cmd_config() {
    echo ""
    echo -e "  ${CYAN}◆${NC} ${BOLD}rhino config${NC}"
    echo -e "  ${DIM}$RHINO_DIR/config/rhino.yml${NC}"
    echo ""

    if [[ ! -f "$RHINO_DIR/config/rhino.yml" ]]; then
        echo -e "  ${RED}✗${NC} rhino.yml not found"
        return 1
    fi

    echo -e "  ${BOLD}Scoring${NC}"
    printf "    cache         %ss\n" "$(cfg scoring.cache_ttl 300)"
    printf "    build gate    %s\n" "$(cfg scoring.build.gate_threshold 70)"
    printf "    health gate   %s\n" "$(cfg scoring.health_gate_threshold 20)"
    printf "    health warn   %s\n" "$(cfg scoring.health_warn_threshold 40)"
    printf "    onboard cap   %s\n" "$(cfg scoring.onboarding_cap 50)"
    echo ""
    echo -e "  ${BOLD}Taste${NC}"
    printf "    max routes    %s\n" "$(cfg taste.max_routes 8)"
    printf "    screenshots   %s\n" "$(cfg taste.max_screenshots 24)"
    printf "    cache         %ss\n" "$(cfg taste.cache_ttl 7200)"
    echo ""
    echo -e "  ${BOLD}Experiments${NC}"
    printf "    moonshot      every %s\n" "$(cfg experiments.moonshot_every_n 5)"
    printf "    max files     %s\n" "$(cfg experiments.max_files_per_experiment 5)"
    echo ""
    echo -e "  ${BOLD}Integrity${NC}"
    printf "    max delta     %s pts/commit\n" "$(cfg integrity.max_single_commit_delta 15)"
    printf "    plateau       %s experiments\n" "$(cfg integrity.plateau_experiments 5)"
    echo ""
}

# ============================================================
# DATA
# ============================================================
cmd_data() {
    bash "$RHINO_DIR/bin/data.sh" "${@:-.}"
}

# ============================================================
# GO (autonomous build loop via Claude Code)
# ============================================================
cmd_go() {
    require_dep "claude" "rhino go (autonomous build loop)"
    echo ""
    echo -e "  ${CYAN}◆${NC} ${BOLD}rhino go${NC}"
    echo -e "  ${DIM}Starting autonomous build loop...${NC}"
    echo ""
    claude "/go $*"
}

# ============================================================
# BENCH (calibration check — run score against fixture repos)
# ============================================================
cmd_bench() {
    bash "$RHINO_DIR/bin/bench.sh" "$@"
}

# ============================================================
# FEATURE
# ============================================================
cmd_feature() {
    bash "$RHINO_DIR/bin/feature.sh" "$@"
}

# ============================================================
# SELF
# ============================================================
cmd_self() {
    bash "$RHINO_DIR/bin/self.sh" "$@"
}

# ============================================================
# PLAN
# ============================================================
cmd_plan() {
    bash "$RHINO_DIR/bin/plan.sh" "$@"
}

# ============================================================
# TODO
# ============================================================
cmd_todo() {
    bash "$RHINO_DIR/bin/todo.sh" "$@"
}

# ============================================================
# TEST
# ============================================================
cmd_test() {
    local total=0 passed=0 failed=0
    local test_dir="$RHINO_DIR/tests"

    if [[ ! -d "$test_dir" ]] || ! ls "$test_dir"/*.test.sh >/dev/null 2>&1; then
        echo -e "  ${YELLOW}⚠${NC} No test files found in tests/"
        return 1
    fi

    for test_file in "$test_dir"/*.test.sh; do
        [[ ! -f "$test_file" ]] && continue
        local name
        name=$(basename "$test_file" .test.sh)
        echo -e "  ${BOLD}$name${NC}"
        if bash "$test_file" 2>&1 | sed 's/^/    /'; then
            passed=$((passed + 1))
        else
            failed=$((failed + 1))
        fi
        total=$((total + 1))
        echo ""
    done

    echo -e "  ${BOLD}$total suites${NC}: ${GREEN}$passed passed${NC}"
    [[ "$failed" -gt 0 ]] && echo -e "  ${RED}$failed failed${NC}"
    [[ "$failed" -gt 0 ]] && return 1 || return 0
}

# ============================================================
# EVAL
# ============================================================
cmd_eval() {
    require_dep "jq" "rhino eval"
    local eval_script="$RHINO_DIR/bin/eval.sh"
    if [[ ! -f "$eval_script" ]]; then
        echo -e "${RED}eval.sh not found at $eval_script${NC}"
        exit 1
    fi
    bash "$eval_script" "${@:-.}"
}

# ============================================================
# HELP
# ============================================================
cmd_help() {
    echo ""
    echo -e "  ${CYAN}◆${NC} ${BOLD}rhino${NC} ${DIM}v${VERSION}${NC}"
    echo -e "  ${DIM}is my product good?${NC}"
    echo ""
    echo -e "  ${BOLD}Usage${NC}  rhino <command> [args...]"
    echo ""
    echo -e "  ${BOLD}Measure${NC}"
    echo -e "    eval [dir]      ${DIM}Run assertions — the one command${NC}"
    echo -e "    taste [dir]     ${DIM}Visual eval (Claude Vision, expensive)${NC}"
    echo -e "    score [dir]     ${DIM}Score for scripts/CI (--quiet for number)${NC}"
    echo ""
    echo -e "  ${BOLD}Features${NC}"
    echo -e "    feature         ${DIM}List all features with pass rates${NC}"
    echo -e "    feature <name>  ${DIM}View one feature's assertions${NC}"
    echo -e "    feature detect  ${DIM}Auto-detect features from codebase${NC}"
    echo ""
    echo -e "  ${BOLD}Build${NC}"
    echo -e "    plan            ${DIM}View/manage build plan${NC}"
    echo -e "    todo            ${DIM}Persistent backlog${NC}"
    echo -e "    test            ${DIM}Run test suites${NC}"
    echo ""
    echo -e "  ${BOLD}System${NC}"
    echo -e "    init            ${DIM}Bootstrap rhino-os into any repo${NC}"
    echo -e "    status          ${DIM}Health overview${NC}"
    echo -e "    self            ${DIM}Self-diagnostic${NC}"
    echo -e "    bench           ${DIM}Calibration check${NC}"
    echo -e "    config          ${DIM}Show configuration${NC}"
    echo ""
    echo -e "  ${BOLD}In Claude Code${NC}"
    echo -e "    ${DIM}/eval [feature]    Is my product good?${NC}"
    echo -e "    ${DIM}/plan [feature]    Find the bottleneck${NC}"
    echo -e "    ${DIM}/go [feature]      Build autonomously${NC}"
    echo -e "    ${DIM}/init             Bootstrap any repo${NC}"
    echo ""
}

# ============================================================
# MAIN
# ============================================================
case "${1:-help}" in
    score)      shift; cmd_score "$@" ;;
    taste)      shift; cmd_taste "$@" ;;
    eval)       shift; cmd_eval "$@" ;;
    bench)      shift; cmd_bench "$@" ;;
    data)       shift; cmd_data "$@" ;;
    plan)       shift; cmd_plan "$@" ;;
    todo)       shift; cmd_todo "$@" ;;
    go)         shift; cmd_go "$@" ;;
    feature|feat) shift; cmd_feature "$@" ;;
    self)       shift; cmd_self "$@" ;;
    test)       shift; cmd_test "$@" ;;
    status)     cmd_status ;;
    config)     cmd_config ;;
    init)       shift; bash "$RHINO_DIR/bin/init.sh" "$@" ;;
    install)    shift; bash "$RHINO_DIR/install.sh" "$@" ;;
    uninstall)  shift; bash "$RHINO_DIR/uninstall.sh" "$@" ;;
    help|--help|-h) cmd_help ;;
    version|--version|-v) echo "rhino v${VERSION}" ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        echo "Run 'rhino help' for available commands."
        exit 1
        ;;
esac
