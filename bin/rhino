    fi

    # 6. Summary
    echo ""
    echo -e "${BOLD}=== Ready ===${NC}"
    echo ""
    echo "  Baseline score: ${score_num}/100"
    if [[ -f ".claude/plans/active-plan.md" ]]; then
        local plan_title
        plan_title=$(head -1 .claude/plans/active-plan.md | sed 's/^#\s*//')
        echo "  Active plan: $plan_title"
    else
        echo "  Active plan: none — say 'run strategy' to create one"
