#!/usr/bin/env bash
set -euo pipefail

# rhino — CLI wrapper for rhino-os
# Unifies agent invocation, state inspection, knowledge backup, and system health.

VERSION="1.0.0"
RHINO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CLAUDE_DIR="$HOME/.claude"
LOG_DIR="$CLAUDE_DIR/logs"
STATE_DIR="$CLAUDE_DIR/state"
KNOWLEDGE_DIR="$CLAUDE_DIR/knowledge"

mkdir -p "$LOG_DIR" "$STATE_DIR"

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# --- Helpers ---

log_start() {
    local agent="$1"
    local log_file="$LOG_DIR/${agent}-$(date +%Y-%m-%d).log"
    echo "$(date '+%Y-%m-%d %H:%M:%S') — Starting $agent" >> "$log_file"
    echo "$log_file"
}

log_end() {
    local agent="$1"
    local log_file="$LOG_DIR/${agent}-$(date +%Y-%m-%d).log"
    echo "$(date '+%Y-%m-%d %H:%M:%S') — $agent complete" >> "$log_file"
}

check_claude() {
    if ! command -v claude &> /dev/null; then
        echo -e "${RED}Error: claude CLI not found${NC}"
        echo "Install: https://docs.anthropic.com/en/docs/claude-code"
        exit 1
    fi
}

# --- Agent runner ---

run_agent() {
    local agent="$1"
    shift
    local budget="${RHINO_BUDGET:-}"
    local prompt="$*"

    check_claude

    local log_file
    log_file="$(log_start "$agent")"

    local args=(
        -p
        --agent "$agent"
        --output-format stream-json
    )

    # Per-agent defaults
    case "$agent" in
        sweep)
            budget="${budget:-2.00}"
            [[ -z "$prompt" ]] && prompt="Run the sweep. Produce the brief. Classify all items. Do NOT auto-dispatch RED items — list them for human review."
            ;;
        scout)
            budget="${budget:-2.00}"
            [[ -z "$prompt" ]] && prompt="Run a standard scouting session. Follow all steps in order."
            ;;
        builder)
            [[ -z "$prompt" ]] && prompt="Auto-detect mode from context and proceed."
            ;;
        strategist)
            budget="${budget:-2.00}"
            [[ -z "$prompt" ]] && prompt="Run a full strategy assessment."
            ;;
        design-engineer)
            budget="${budget:-2.00}"
            [[ -z "$prompt" ]] && prompt="Auto-detect mode from context and proceed."
            ;;
    esac

    if [[ -n "$budget" ]]; then
        args+=(--max-budget-usd "$budget")
    fi

    echo -e "${BLUE}rhino ${agent}${NC} ${DIM}(budget: \$${budget:-unlimited})${NC}"
    echo -e "${DIM}logging to: $log_file${NC}"
    echo ""

    claude "${args[@]}" "$prompt" 2>> "$log_file" | tee -a "$log_file"

    log_end "$agent"
}

# --- Subcommands ---

cmd_sweep()   { run_agent sweep "$@"; }
cmd_scout()   { run_agent scout "$@"; }
cmd_build()   { run_agent builder "$@"; }
cmd_strategy(){ run_agent strategist "$@"; }
cmd_design()  { run_agent design-engineer "$@"; }

cmd_status() {
    echo -e "${BOLD}=== rhino status ===${NC}"
    echo ""

    # Sweep state
    local sweep_file="$STATE_DIR/sweep-latest.md"
    if [[ -f "$sweep_file" ]]; then
        local sweep_age
        sweep_age=$(( ( $(date +%s) - $(stat -f %m "$sweep_file" 2>/dev/null || stat -c %Y "$sweep_file" 2>/dev/null) ) / 3600 ))
        echo -e "${GREEN}Sweep:${NC} last run ${sweep_age}h ago"
        # Show first line (date header)
        head -1 "$sweep_file" | sed 's/^# /  /'
        # Show focus if present
        grep -A1 "^## Focus" "$sweep_file" 2>/dev/null | tail -1 | sed 's/^/  /' || true
    else
        echo -e "${YELLOW}Sweep:${NC} no state file found"
    fi
    echo ""

    # Knowledge freshness
    echo -e "${BOLD}Knowledge:${NC}"
    for kdir in "$KNOWLEDGE_DIR"/*/; do
        [[ ! -d "$kdir" ]] && continue
        local kname
        kname="$(basename "$kdir")"
        [[ "$kname" == "_template" ]] && continue
        local kfile="$kdir/knowledge.md"
        if [[ -f "$kfile" ]]; then
            local kage
            kage=$(( ( $(date +%s) - $(stat -f %m "$kfile" 2>/dev/null || stat -c %Y "$kfile" 2>/dev/null) ) / 86400 ))
            local freshness="${GREEN}fresh${NC}"
            (( kage > 7 )) && freshness="${YELLOW}${kage}d old${NC}"
            (( kage > 30 )) && freshness="${RED}stale (${kage}d)${NC}"
            local lines
            lines=$(wc -l < "$kfile" | tr -d ' ')
            echo -e "  $kname: ${freshness} (${lines} lines)"
        fi
    done
    echo ""

    # Intelligence layer
    echo -e "${BOLD}Intelligence:${NC}"

    # Portfolio
    local portfolio_file="$KNOWLEDGE_DIR/portfolio.json"
    if [[ -f "$portfolio_file" ]]; then
        if command -v jq &> /dev/null; then
            local proj_count
            proj_count=$(jq '.projects | length' "$portfolio_file" 2>/dev/null || echo "?")
            local last_review
            last_review=$(jq -r '.last_review // "never"' "$portfolio_file" 2>/dev/null || echo "unknown")
            echo -e "  Portfolio: ${proj_count} projects, last review: ${last_review}"
        else
            echo -e "  Portfolio: $(wc -l < "$portfolio_file" | tr -d ' ') lines (install jq for details)"
        fi
    else
        echo -e "  Portfolio: ${DIM}not initialized${NC}"
    fi

    # Landscape
    local landscape_file="$KNOWLEDGE_DIR/landscape.json"
    if [[ -f "$landscape_file" ]]; then
        if command -v jq &> /dev/null; then
            local pos_count
            pos_count=$(jq '.positions | length' "$landscape_file" 2>/dev/null || echo "?")
            local landscape_updated
            landscape_updated=$(jq -r '.updated // "never"' "$landscape_file" 2>/dev/null || echo "unknown")
            echo -e "  Landscape: ${pos_count} positions, updated: ${landscape_updated}"
        else
            echo -e "  Landscape: $(wc -l < "$landscape_file" | tr -d ' ') lines (install jq for details)"
        fi
    else
        echo -e "  Landscape: ${DIM}not initialized${NC}"
    fi

    # Taste
    local taste_file="$KNOWLEDGE_DIR/taste.jsonl"
    if [[ -f "$taste_file" ]]; then
        local taste_count
        taste_count=$(wc -l < "$taste_file" | tr -d ' ')
        echo -e "  Taste: ${taste_count} signals"
    else
        echo -e "  Taste: ${DIM}no signals recorded${NC}"
    fi
    echo ""

    # Recent logs
    echo -e "${BOLD}Recent activity:${NC}"
    local found_logs=false
    for logfile in "$LOG_DIR"/*.log; do
        [[ ! -f "$logfile" ]] && continue
        found_logs=true
        local logname
        logname="$(basename "$logfile" .log)"
        local logdate
        logdate="$(echo "$logname" | grep -oE '[0-9]{4}-[0-9]{2}-[0-9]{2}' || echo "unknown")"
        local agent_name
        agent_name="$(echo "$logname" | sed 's/-[0-9]\{4\}-[0-9]\{2\}-[0-9]\{2\}$//')"
        echo -e "  ${DIM}$logdate${NC} $agent_name"
    done | sort -r | head -5
    [[ "$found_logs" == "false" ]] && echo "  (no logs found)"
    echo ""

    # Usage stats
    local usage_file="$LOG_DIR/usage.jsonl"
    if [[ -f "$usage_file" ]]; then
        local today
        today="$(date -u +%Y-%m-%d)"
        local today_count
        today_count=$(grep -c "$today" "$usage_file" 2>/dev/null || echo "0")
        local total_count
        total_count=$(wc -l < "$usage_file" | tr -d ' ')
        echo -e "${BOLD}Usage:${NC} ${today_count} tool calls today, ${total_count} total"
    fi
    echo ""

    # Focus drift detection
    if [[ -f "$usage_file" ]] && command -v jq &> /dev/null; then
        local week_ago
        week_ago="$(date -u -v-7d +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date -u -d '7 days ago' +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo "")"
        if [[ -n "$week_ago" ]]; then
            # Count edits per project in last 7 days
            local drift_data
            drift_data=$(awk -v cutoff="$week_ago" '
                {
                    if (match($0, /"ts":"([^"]+)"/, ts) && match($0, /"tool":"(Edit|Write)"/) && match($0, /"project":"([^"]*)"/, proj)) {
                        if (ts[1] >= cutoff && proj[1] != "") {
                            counts[proj[1]]++
                            total++
                        }
                    }
                }
                END {
                    if (total > 0) {
                        for (p in counts) {
                            pct = int(counts[p] * 100 / total)
                            printf "  %s: %d%% (%d edits)\n", p, pct, counts[p]
                        }
                    }
                }
            ' "$usage_file")

            if [[ -n "$drift_data" ]]; then
                echo -e "${BOLD}Focus allocation (7d):${NC}"
                echo "$drift_data" | sort -t: -k2 -rn

                # Check for drift against portfolio focus
                if [[ -f "$portfolio_file" ]]; then
                    local primary_focus
                    primary_focus=$(jq -r '.focus.primary // empty' "$portfolio_file" 2>/dev/null)
                    if [[ -n "$primary_focus" ]]; then
                        local primary_pct
                        primary_pct=$(echo "$drift_data" | grep "$primary_focus" | grep -oE '[0-9]+%' | head -1 | tr -d '%')
                        if [[ -n "$primary_pct" && "$primary_pct" -lt 50 ]]; then
                            echo -e "  ${YELLOW}DRIFT:${NC} ${primary_focus} is primary focus but only ${primary_pct}% of edits"
                        fi
                    fi
                fi
                echo ""
            fi
        fi
    fi

    # Code style summary (separate from taste)
    local style_file="$LOG_DIR/code-style.jsonl"
    if [[ -f "$style_file" ]]; then
        local style_count
        style_count=$(wc -l < "$style_file" | tr -d ' ')
        echo -e "${BOLD}Code style:${NC} ${style_count} observations (auto-detected formatting patterns)"
    fi
}

cmd_backup() {
    echo -e "${BOLD}=== rhino backup ===${NC}"

    local backup_base="$CLAUDE_DIR/backups"
    local timestamp
    timestamp="$(date +%Y%m%d-%H%M%S)"
    local backup_dir="$backup_base/knowledge-$timestamp"

    mkdir -p "$backup_dir"

    if [[ -d "$KNOWLEDGE_DIR" ]]; then
        cp -r "$KNOWLEDGE_DIR"/* "$backup_dir/" 2>/dev/null || true
        echo -e "${GREEN}Knowledge backed up to:${NC}"
        echo "  $backup_dir"

        # Count what was backed up
        local file_count
        file_count=$(find "$backup_dir" -type f | wc -l | tr -d ' ')
        echo -e "  ${file_count} files"
    else
        echo -e "${YELLOW}No knowledge directory found${NC}"
    fi

    # Also back up state
    if [[ -d "$STATE_DIR" ]]; then
        cp -r "$STATE_DIR" "$backup_dir/_state" 2>/dev/null || true
        echo -e "  State files included"
    fi

    # Prune old backups (keep last 10)
    local backup_count
    backup_count=$(ls -d "$backup_base"/knowledge-* 2>/dev/null | wc -l | tr -d ' ')
    if (( backup_count > 10 )); then
        ls -dt "$backup_base"/knowledge-* | tail -n +11 | xargs rm -rf
        echo -e "  ${DIM}Pruned old backups (keeping last 10)${NC}"
    fi
}

cmd_doctor() {
    echo -e "${BOLD}=== rhino doctor ===${NC}"
    echo ""
    local issues=0

    # Check claude CLI
    if command -v claude &> /dev/null; then
        echo -e "${GREEN}[OK]${NC} claude CLI found: $(which claude)"
    else
        echo -e "${RED}[FAIL]${NC} claude CLI not found"
        ((issues++))
    fi

    # Check symlinks
    echo ""
    echo -e "${BOLD}Symlinks:${NC}"
    for agent in "$CLAUDE_DIR"/agents/*.md; do
        [[ ! -e "$agent" ]] && continue
        if [[ -L "$agent" ]]; then
            local target
            target="$(readlink "$agent")"
            if [[ -f "$target" ]]; then
                echo -e "  ${GREEN}[OK]${NC} $(basename "$agent")"
            else
                echo -e "  ${RED}[BROKEN]${NC} $(basename "$agent") → $target"
                ((issues++))
            fi
        fi
    done

    # Check MCP server
    echo ""
    echo -e "${BOLD}MCP Server:${NC}"
    if [[ -f "$RHINO_DIR/src/mcp-server/index.ts" ]]; then
        if [[ -d "$RHINO_DIR/src/mcp-server/node_modules" ]]; then
            echo -e "  ${GREEN}[OK]${NC} rhino-state MCP server installed"
        else
            echo -e "  ${YELLOW}[WARN]${NC} rhino-state MCP server not installed (run: cd src/mcp-server && npm install)"
            ((issues++))
        fi
    else
        echo -e "  ${DIM}[SKIP]${NC} MCP server not present"
    fi

    # Check config.json for MCP entry
    if [[ -f "$CLAUDE_DIR/config.json" ]]; then
        if grep -q "rhino-state" "$CLAUDE_DIR/config.json" 2>/dev/null; then
            echo -e "  ${GREEN}[OK]${NC} rhino-state registered in config.json"
        else
            echo -e "  ${YELLOW}[WARN]${NC} rhino-state not in config.json"
        fi
    fi

    # Check LaunchAgents
    echo ""
    echo -e "${BOLD}LaunchAgents:${NC}"
    for label in com.claude-os.sweep com.claude-os.scout; do
        if launchctl list "$label" &>/dev/null; then
            echo -e "  ${GREEN}[OK]${NC} $label loaded"
        else
            echo -e "  ${YELLOW}[WARN]${NC} $label not loaded"
        fi
    done

    # Check stale state files
    echo ""
    echo -e "${BOLD}State files:${NC}"
    local stale_count=0
    for state_file in "$STATE_DIR"/*; do
        [[ ! -f "$state_file" ]] && continue
        local file_age
        file_age=$(( ( $(date +%s) - $(stat -f %m "$state_file" 2>/dev/null || stat -c %Y "$state_file" 2>/dev/null) ) / 86400 ))
        if (( file_age > 7 )); then
            echo -e "  ${YELLOW}[STALE]${NC} $(basename "$state_file") (${file_age}d old)"
            ((stale_count++))
        else
            echo -e "  ${GREEN}[OK]${NC} $(basename "$state_file") (${file_age}d old)"
        fi
    done
    [[ $stale_count -gt 0 ]] && echo -e "  ${DIM}Run sweep to clean stale state${NC}"

    # Check knowledge freshness
    echo ""
    echo -e "${BOLD}Knowledge health:${NC}"
    for kdir in "$KNOWLEDGE_DIR"/*/; do
        [[ ! -d "$kdir" ]] && continue
        local kname
        kname="$(basename "$kdir")"
        [[ "$kname" == "_template" ]] && continue
        local kfile="$kdir/knowledge.md"
        if [[ -f "$kfile" ]]; then
            local ksize
            ksize=$(wc -c < "$kfile" | tr -d ' ')
            local klines
            klines=$(wc -l < "$kfile" | tr -d ' ')
            if (( klines > 200 )); then
                echo -e "  ${YELLOW}[WARN]${NC} $kname/knowledge.md is ${klines} lines (max recommended: 200)"
                ((issues++))
            else
                echo -e "  ${GREEN}[OK]${NC} $kname/knowledge.md (${klines} lines)"
            fi
        fi
    done

    # Check API server
    echo ""
    echo -e "${BOLD}API Server:${NC}"
    if [[ -f "$RHINO_DIR/src/api-server/index.ts" ]]; then
        if [[ -d "$RHINO_DIR/src/api-server/node_modules" ]]; then
            echo -e "  ${GREEN}[OK]${NC} API server installed"
        else
            echo -e "  ${YELLOW}[WARN]${NC} API server not installed (run: cd src/api-server && npm install)"
        fi
    else
        echo -e "  ${DIM}[SKIP]${NC} API server not present"
    fi

    echo ""
    if (( issues == 0 )); then
        echo -e "${GREEN}${BOLD}All checks passed${NC}"
    else
        echo -e "${YELLOW}${BOLD}${issues} issue(s) found${NC}"
    fi
}

cmd_taste() {
    local subcommand="${1:-summary}"

    local taste_file="$KNOWLEDGE_DIR/taste.jsonl"
    local style_file="$LOG_DIR/code-style.jsonl"

    case "$subcommand" in
        summary)
            echo -e "${BOLD}=== rhino taste ===${NC}"
            echo ""
            echo -e "${DIM}Taste = macro judgment (what to build, kill, prioritize)${NC}"
            echo -e "${DIM}Code style = formatting (camelCase, semicolons) — separate concern${NC}"
            echo ""

            # Taste signals
            if [[ -f "$taste_file" ]]; then
                echo -e "${BOLD}Judgment signals:${NC}"
                if command -v jq &> /dev/null; then
                    jq -r '"\(.strength)/\(.domain): \(.signal)"' "$taste_file" 2>/dev/null | sort | while read -r line; do
                        local str="${line%%/*}"
                        local rest="${line#*/}"
                        case "$str" in
                            strong)   echo -e "  ${GREEN}[strong]${NC} $rest" ;;
                            moderate) echo -e "  ${YELLOW}[moderate]${NC} $rest" ;;
                            weak)     echo -e "  ${DIM}[weak]${NC} $rest" ;;
                        esac
                    done
                else
                    local count
                    count=$(wc -l < "$taste_file" | tr -d ' ')
                    echo "  $count signals (install jq for details)"
                fi
            else
                echo -e "  ${DIM}No taste signals yet — agents record these as they observe your decisions${NC}"
            fi
            echo ""

            # Code style (separate from taste)
            if [[ -f "$style_file" ]]; then
                echo -e "${BOLD}Code style (auto-detected, NOT taste):${NC}"
                local total_styles
                total_styles=$(wc -l < "$style_file" | tr -d ' ')
                echo -e "  ${total_styles} observations"

                if command -v jq &> /dev/null; then
                    jq -r '.s[]' "$style_file" 2>/dev/null | sort | uniq -c | sort -rn | head -5 | while read -r count pattern; do
                        echo -e "  ${DIM}${count}x${NC} $pattern"
                    done
                fi
            fi
            ;;
        export)
            echo -e "${BOLD}=== taste export ===${NC}"

            if [[ ! -f "$taste_file" && ! -f "$style_file" ]]; then
                echo -e "${YELLOW}Nothing to export${NC}"
                return 1
            fi

            local export_file="$HOME/taste-profile-$(date +%Y%m%d).json"

            # Build export via node if MCP server is available, otherwise basic
            if command -v jq &> /dev/null; then
                local signals="[]"
                if [[ -f "$taste_file" ]]; then
                    signals=$(jq -s '.' "$taste_file" 2>/dev/null || echo "[]")
                fi

                local styles="{}"
                if [[ -f "$style_file" ]]; then
                    styles=$(jq -r '.s[]' "$style_file" 2>/dev/null | sort | uniq -c | sort -rn | awk '{printf "\"%s\": %d,\n", $2, $1}' | sed '$ s/,$//' | { echo "{"; cat; echo "}"; })
                fi

                jq -n \
                    --argjson signals "$signals" \
                    --argjson code_style "$styles" \
                    '{version: "1.0", exported: now | todate, taste_signals: $signals, code_style: $code_style}' \
                    > "$export_file" 2>/dev/null

                echo -e "${GREEN}Exported to:${NC} $export_file"
                echo -e "  Judgment signals: $(echo "$signals" | jq 'length')"
                echo -e "  Code style patterns: $(echo "$styles" | jq 'keys | length') categories"
            else
                echo -e "${YELLOW}jq required for export${NC}"
                return 1
            fi
            ;;
        *)
            echo -e "${RED}Unknown taste subcommand: $subcommand${NC}"
            echo "Usage: rhino taste [summary|export]"
            return 1
            ;;
    esac
}

cmd_capture() {
    # NOTE: `claude -p` starts a NEW session with NO memory of the previous one.
    # So we capture from observable artifacts: git diff, usage logs, plan state.
    # This gives real data, not hallucinated session summaries.

    local project_name
    project_name="$(basename "$(pwd)")"
    local sessions_dir="$KNOWLEDGE_DIR/sessions"
    mkdir -p "$sessions_dir"
    local target_file="$sessions_dir/${project_name}.md"
    local today
    today="$(date +%Y-%m-%d)"

    echo -e "${BLUE}rhino capture${NC} — extracting session artifacts for ${BOLD}${project_name}${NC}"

    local capture=""

    # 1. Git activity (what actually changed)
    if git rev-parse --is-inside-work-tree &>/dev/null; then
        local recent_commits
        recent_commits=$(git log --oneline --since="6 hours ago" 2>/dev/null | head -10)
        if [[ -n "$recent_commits" ]]; then
            capture+="### Commits
$recent_commits
"
        fi

        local uncommitted
        uncommitted=$(git diff --stat 2>/dev/null | tail -5)
        if [[ -n "$uncommitted" ]]; then
            capture+="### Uncommitted changes
$uncommitted
"
        fi
    fi

    # 2. Tool activity (what tools were used, on what)
    local usage_file="$LOG_DIR/usage.jsonl"
    if [[ -f "$usage_file" ]] && command -v jq &>/dev/null; then
        local six_hours_ago
        six_hours_ago="$(date -u -v-6H +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date -u -d '6 hours ago' +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo "")"
        if [[ -n "$six_hours_ago" ]]; then
            local edit_count
            edit_count=$(awk -v cutoff="$six_hours_ago" -v proj="$project_name" '
                /"ts":/ {
                    match($0, /"ts":"([^"]+)"/, ts)
                    if (ts[1] >= cutoff) {
                        match($0, /"tool":"([^"]+)"/, tool)
                        if (tool[1] == "Edit" || tool[1] == "Write") count++
                    }
                }
                END { print count+0 }
            ' "$usage_file")
            if (( edit_count > 0 )); then
                capture+="### Activity
${edit_count} edits in last 6h
"
            fi
        fi
    fi

    # 3. Active plan state
    local plan_file="$CLAUDE_DIR/plans/active-plan.md"
    if [[ -f "$plan_file" ]]; then
        local plan_title
        plan_title=$(head -3 "$plan_file" | grep -E '^#' | head -1 || echo "Active plan exists")
        capture+="### Plan
$plan_title
"
    fi

    # 4. Taste signals recorded today
    local taste_file="$KNOWLEDGE_DIR/taste.jsonl"
    if [[ -f "$taste_file" ]]; then
        local today_taste
        today_taste=$(grep "$today" "$taste_file" 2>/dev/null | head -5)
        if [[ -n "$today_taste" ]] && command -v jq &>/dev/null; then
            local taste_summary
            taste_summary=$(echo "$today_taste" | jq -r '"[\(.domain)] \(.signal)"' 2>/dev/null)
            if [[ -n "$taste_summary" ]]; then
                capture+="### Taste signals recorded
$taste_summary
"
            fi
        fi
    fi

    if [[ -z "$capture" ]]; then
        echo -e "${YELLOW}Nothing to capture${NC} — no recent git activity, edits, or taste signals"
        return 0
    fi

    # Write to session file
    {
        echo ""
        echo "## $today — $project_name"
        echo "$capture"
    } >> "$target_file"

    echo -e "${GREEN}Captured to:${NC} $target_file"

    # Prune entries older than 60 days
    if [[ -f "$target_file" ]]; then
        local sixty_days_ago
        sixty_days_ago=$(date -v-60d +%Y-%m-%d 2>/dev/null || date -d '60 days ago' +%Y-%m-%d 2>/dev/null || echo "")
        if [[ -n "$sixty_days_ago" ]]; then
            local tmpfile
            tmpfile=$(mktemp)
            awk -v cutoff="$sixty_days_ago" '
                /^## [0-9]{4}-[0-9]{2}-[0-9]{2}/ {
                    match($0, /[0-9]{4}-[0-9]{2}-[0-9]{2}/, arr)
                    printing = (arr[0] >= cutoff)
                }
                printing { print }
            ' "$target_file" > "$tmpfile"
            mv "$tmpfile" "$target_file"
        fi
    fi
}

cmd_serve() {
    check_claude

    local port="${RHINO_PORT:-7890}"
    echo -e "${BLUE}rhino serve${NC} — starting API server on port $port"

    if [[ ! -f "$RHINO_DIR/src/api-server/index.ts" ]]; then
        echo -e "${RED}Error: API server not found at src/api-server/index.ts${NC}"
        echo "Run install.sh to set up the API server."
        exit 1
    fi

    if [[ ! -d "$RHINO_DIR/src/api-server/node_modules" ]]; then
        echo -e "${YELLOW}Installing API server dependencies...${NC}"
        (cd "$RHINO_DIR/src/api-server" && npm install)
    fi

    RHINO_PORT="$port" RHINO_DIR="$RHINO_DIR" npx --prefix "$RHINO_DIR/src/api-server" tsx "$RHINO_DIR/src/api-server/index.ts"
}

cmd_help() {
    echo -e "${BOLD}rhino${NC} v${VERSION} — CLI for rhino-os"
    echo ""
    echo -e "${BOLD}Usage:${NC} rhino <command> [args...]"
    echo ""
    echo -e "${BOLD}Agent commands:${NC}"
    echo "  sweep              Run daily triage + system health"
    echo "  scout              Run trend scanning + opportunity intelligence"
    echo "  build [prompt]     Run builder agent (auto-detects mode)"
    echo "  strategy [prompt]  Run strategist agent"
    echo "  design [prompt]    Run design-engineer agent"
    echo ""
    echo -e "${BOLD}System commands:${NC}"
    echo "  status             Show system state, knowledge freshness, focus drift"
    echo "  taste [summary]    View taste profile (signals + auto-extracted patterns)"
    echo "  taste export       Export portable taste profile to ~/taste-profile.json"
    echo "  capture            Extract session decisions/preferences to knowledge"
    echo "  backup             Snapshot knowledge to timestamped backup"
    echo "  doctor             Check system health (symlinks, MCP, launchd, state)"
    echo "  serve              Start localhost API server (port 7890)"
    echo ""
    echo -e "${BOLD}Environment:${NC}"
    echo "  RHINO_BUDGET       Override default budget cap (e.g., RHINO_BUDGET=5.00 rhino sweep)"
    echo "  RHINO_PORT         API server port (default: 7890)"
    echo "  RHINO_API_KEY      API server authentication key"
    echo ""
    echo -e "${BOLD}Examples:${NC}"
    echo "  rhino sweep                              # daily triage"
    echo "  rhino build \"implement task 3\"            # build specific task"
    echo "  rhino design \"audit\"                      # design audit mode"
    echo "  RHINO_BUDGET=5.00 rhino scout             # scout with \$5 budget"
    echo "  rhino serve                               # start API on :7890"
}

# --- Main ---

case "${1:-help}" in
    sweep)      shift; cmd_sweep "$@" ;;
    scout)      shift; cmd_scout "$@" ;;
    build)      shift; cmd_build "$@" ;;
    strategy)   shift; cmd_strategy "$@" ;;
    design)     shift; cmd_design "$@" ;;
    status)     cmd_status ;;
    taste)      shift; cmd_taste "$@" ;;
    capture)    cmd_capture ;;
    backup)     cmd_backup ;;
    doctor)     cmd_doctor ;;
    serve)      cmd_serve ;;
    help|--help|-h) cmd_help ;;
    version|--version|-v) echo "rhino v${VERSION}" ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        echo "Run 'rhino help' for usage."
        exit 1
        ;;
esac
