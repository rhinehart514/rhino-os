    echo -e "    init            ${DIM}Bootstrap rhino-os into any repo${NC}"
    echo -e "    update          ${DIM}Pull latest + refresh symlinks${NC}"
    echo -e "    doctor          ${DIM}Verify install health (symlinks, deps)${NC}"
