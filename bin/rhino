#!/usr/bin/env bash
set -euo pipefail

# rhino — CLI for rhino-os v5
# Measurement tools: score, taste, status, setup, config
# Agent work happens in Claude Code via skills: /plan, /build, /research, /status, /setup, /go

VERSION="5.0.0"
_RHINO_SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$_RHINO_SOURCE" ]]; do
    _RHINO_SOURCE="$(readlink "$_RHINO_SOURCE")"
done
RHINO_DIR="$(cd "$(dirname "$_RHINO_SOURCE")/.." && pwd)"

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# --- Config reader ---
source "$RHINO_DIR/bin/lib/config.sh"

# ============================================================
# SCORE
# ============================================================
cmd_score() {
    "$RHINO_DIR/bin/score.sh" "${@:-.}"
}

# ============================================================
# TASTE
# ============================================================
cmd_taste() {
    local args=("$@")
    if [[ ${#args[@]} -eq 0 ]]; then
        args=(".")
    fi
    node "$RHINO_DIR/bin/taste.mjs" "${args[@]}"
}

# ============================================================
# STATUS
# ============================================================
cmd_status() {
    echo -e "${BOLD}rhino-os v${VERSION}${NC}"
    echo ""

    # Claude CLI check
    if command -v claude &>/dev/null; then
        echo -e "${GREEN}[OK]${NC} claude CLI"
    else
        echo -e "${RED}[FAIL]${NC} claude CLI not found"
    fi

    # Product map
    if [[ -f ".claude/product-map.yml" ]]; then
        echo -e "${GREEN}[OK]${NC} Product map exists"
    else
        echo -e "${DIM}[--]${NC} No product map (run /setup)"
    fi

    # Rules files
    local rules_count=0
    for f in .claude/rules/identity.md .claude/rules/product-brief.md .claude/rules/hypotheses.md; do
        [[ -f "$f" ]] && ((rules_count++))
    done
    echo -e "${GREEN}[OK]${NC} Rules: ${rules_count}/3 files"

    # Last score
    if [[ -f ".claude/cache/score-cache.json" ]] && command -v jq &>/dev/null; then
        local score warnings
        score=$(jq -r '.total // "?"' .claude/cache/score-cache.json 2>/dev/null)
        warnings=$(jq -r '.integrity_warnings // [] | join(", ")' .claude/cache/score-cache.json 2>/dev/null)
        local msg="Score: $score"
        [[ -n "$warnings" ]] && msg="$msg  ${YELLOW}$warnings${NC}"
        echo -e "$msg"
    fi

    # Active plan
    if [[ -f ".claude/plans/active-plan.md" ]]; then
        local total done title
        title=$(head -5 .claude/plans/active-plan.md | grep -m1 '^#' | sed 's/^#* *//' || echo "")
        total=$(grep -c '^\- \[' .claude/plans/active-plan.md 2>/dev/null || echo 0)
        done=$(grep -c '^\- \[x\]' .claude/plans/active-plan.md 2>/dev/null || echo 0)
        echo ""
        echo -e "Sprint: ${BOLD}$title${NC} ($done/$total tasks)"
    fi

    echo ""
    echo -e "${DIM}Use /status in Claude Code for the full co-founder briefing${NC}"
}

# ============================================================
# SETUP
# ============================================================
cmd_setup() {
    local project_dir="${1:-.}"
    cd "$project_dir"
    echo -e "${BOLD}=== rhino setup: $(basename "$(pwd)") ===${NC}"
    echo ""

    # Create directories
    mkdir -p .claude/{rules,plans,experiments,cache,scores,evals,brains}
    mkdir -p knowledge
    echo -e "  ${GREEN}created${NC} .claude/ structure"

    # Copy brains templates
    for f in longterm.md daily.md experiment-log.md hypothesis-log.md; do
        if [[ ! -f ".claude/brains/$f" && -f "$RHINO_DIR/config/brains/$f" ]]; then
            cp "$RHINO_DIR/config/brains/$f" ".claude/brains/$f"
        fi
    done
    echo -e "  ${GREEN}created${NC} .claude/brains/ templates"

    # Copy beliefs template
    if [[ ! -f ".claude/evals/beliefs.yml" && -f "$RHINO_DIR/config/evals/beliefs.yml" ]]; then
        cp "$RHINO_DIR/config/evals/beliefs.yml" ".claude/evals/beliefs.yml"
        echo -e "  ${GREEN}created${NC} .claude/evals/beliefs.yml"
    fi

    # Copy rule templates
    for f in identity.md product-brief.md hypotheses.md; do
        if [[ ! -f ".claude/rules/$f" ]]; then
            cp "$RHINO_DIR/config/rules/$f" ".claude/rules/$f"
            echo -e "  ${GREEN}created${NC} .claude/rules/$f"
        else
            echo -e "  ${DIM}[skip]${NC} .claude/rules/$f (exists)"
        fi
    done

    # Run baseline score
    echo ""
    echo -e "${BLUE}Running baseline score...${NC}"
    local baseline_score score_num
    baseline_score=$("$RHINO_DIR/bin/score.sh" . --json 2>/dev/null || echo '{"score":0}')
    score_num=$(echo "$baseline_score" | grep -o '"score":[0-9]*' | grep -o '[0-9]*')
    echo -e "  ${BOLD}Baseline: ${score_num:-0}/100${NC}"

    echo ""
    echo -e "${BOLD}Done.${NC} For full interactive onboarding, run ${BLUE}/setup${NC} in Claude Code."
}

# ============================================================
# CONFIG
# ============================================================
cmd_config() {
    echo -e "${BOLD}=== rhino config ===${NC}"
    echo -e "${DIM}Source: $RHINO_DIR/config/rhino.yml${NC}"
    echo ""

    if [[ ! -f "$RHINO_DIR/config/rhino.yml" ]]; then
        echo -e "${RED}No rhino.yml found${NC}"
        return 1
    fi

    echo -e "${BOLD}Scoring:${NC}"
    printf "  cache: %ss  build gate: %s\n" \
        "$(cfg scoring.cache_ttl 300)" \
        "$(cfg scoring.build.gate_threshold 70)"

    echo -e "${BOLD}Taste:${NC}"
    printf "  routes: %s  screenshots: %s  cache: %ss\n" \
        "$(cfg taste.max_routes 8)" \
        "$(cfg taste.max_screenshots 24)" \
        "$(cfg taste.cache_ttl 7200)"

    echo -e "${BOLD}Experiments:${NC}"
    printf "  moonshot: every %s  max files: %s\n" \
        "$(cfg experiments.moonshot_every_n 5)" \
        "$(cfg experiments.max_files_per_experiment 5)"

    echo -e "${BOLD}Integrity:${NC}"
    printf "  max delta: %s  plateau: %s exps\n" \
        "$(cfg integrity.max_single_commit_delta 15)" \
        "$(cfg integrity.plateau_experiments 5)"
}

# ============================================================
# EVAL
# ============================================================
cmd_eval() {
    local eval_script="$RHINO_DIR/bin/eval.sh"
    if [[ ! -f "$eval_script" ]]; then
        echo -e "${RED}eval.sh not found at $eval_script${NC}"
        exit 1
    fi
    bash "$eval_script" "${@:-.}"
}

# ============================================================
# CORPUS
# ============================================================
cmd_corpus() {
    local action="${1:-list}"
    case "$action" in
        list)
            echo -e "${BOLD}=== rhino corpus ===${NC}"
            echo ""
            local corpus_dir="$RHINO_DIR/corpus"
            if [[ ! -d "$corpus_dir" ]]; then
                echo -e "${DIM}No corpus directory found${NC}"
                return
            fi
            for category in ui/saas ui/consumer ui/developer copy/landing copy/onboarding code/patterns; do
                local dir="$corpus_dir/$category"
                if [[ -d "$dir" ]]; then
                    local count
                    count=$(find "$dir" -type f -not -name 'README.md' 2>/dev/null | wc -l | tr -d ' ')
                    echo -e "  ${BOLD}$category${NC}: $count examples"
                fi
            done
            echo ""
            echo -e "${DIM}Use /corpus update [category] in Claude Code to discover new examples${NC}"
            ;;
        add|update)
            echo -e "${YELLOW}Corpus $action runs inside Claude Code.${NC}"
            echo "Use: /corpus $action ${2:-[category]}"
            ;;
        *)
            echo -e "${RED}Unknown corpus action: $action${NC}"
            echo "Usage: rhino corpus [list|add|update]"
            ;;
    esac
}

# ============================================================
# HELP
# ============================================================
cmd_help() {
    echo -e "${BOLD}rhino${NC} v${VERSION} — cofounder, not tool"
    echo ""
    echo -e "${BOLD}Usage:${NC} rhino <command> [args...]"
    echo ""
    echo -e "${BOLD}Measure:${NC}"
    echo "  score [dir]        Structural lint score"
    echo "  taste [dir]        Visual product eval (Claude vision)"
    echo "  eval [dir]         Run belief evals (Tier 1)"
    echo ""
    echo -e "${BOLD}System:${NC}"
    echo "  status             Quick health overview"
    echo "  config             Show configuration"
    echo "  setup [dir]        Bootstrap a project"
    echo "  corpus [action]    Manage taste corpus (list|add|update)"
    echo "  install [--check]  Install/update rhino-os"
    echo ""
    echo -e "${BOLD}Skills (use in Claude Code):${NC}"
    echo "  /plan              Morning — what to work on today"
    echo "  /build             Execute the plan, score every change"
    echo "  /research          When stuck — taste, market, ideas, evals"
    echo "  /eval              Run belief evals + /eval --add"
    echo "  /corpus            Manage taste corpus"
    echo "  /next              Show next task (zero ceremony)"
    echo "  /status            Full co-founder briefing"
    echo "  /setup             Interactive project onboarding"
    echo "  /go                Autonomous loop (NEVER STOP)"
    echo ""
    echo -e "${BOLD}Config:${NC} $RHINO_DIR/config/rhino.yml"
}

# ============================================================
# MAIN
# ============================================================
case "${1:-help}" in
    score)      shift; cmd_score "$@" ;;
    taste)      shift; cmd_taste "$@" ;;
    eval)       shift; cmd_eval "$@" ;;
    status)     cmd_status ;;
    config)     cmd_config ;;
    setup)      shift; cmd_setup "$@" ;;
    corpus)     shift; cmd_corpus "$@" ;;
    install)    shift; bash "$RHINO_DIR/install.sh" "$@" ;;
    help|--help|-h) cmd_help ;;
    version|--version|-v) echo "rhino v${VERSION}" ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        echo "Run 'rhino help' for available commands."
        exit 1
        ;;
esac
