    echo -e "    ${DIM}/taste <url>      Visual product intelligence via Playwright${NC}"
    echo ""
    echo -e "    ${BOLD}Think${NC}"
    echo -e "    ${DIM}/product          Pressure-test assumptions, name the person${NC}"
    echo -e "    ${DIM}/strategy         Market intelligence, honest diagnosis${NC}"
    echo -e "    ${DIM}/discover         What systems should this product have?${NC}"
    echo -e "    ${DIM}/ideate           Evidence-weighted ideas + kill list${NC}"
    echo -e "    ${DIM}/research         Gather evidence before deciding${NC}"
    echo ""
    echo -e "    ${BOLD}Business${NC}  ${DIM}(new in v9)${NC}"
    echo -e "    ${DIM}/money            Pricing, unit economics, channels, runway${NC}"
    echo -e "    ${DIM}/copy             Landing pages, pitch, outreach, release notes${NC}"
