#!/usr/bin/env bash
set -euo pipefail

# rhino — CLI wrapper for rhino-os
# Unifies agent invocation, state inspection, knowledge backup, and system health.

VERSION="1.0.0"
# Follow symlink to find real rhino-os directory
_RHINO_SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$_RHINO_SOURCE" ]]; do
    _RHINO_SOURCE="$(readlink "$_RHINO_SOURCE")"
done
RHINO_DIR="$(cd "$(dirname "$_RHINO_SOURCE")/.." && pwd)"
CLAUDE_DIR="$HOME/.claude"
LOG_DIR="$CLAUDE_DIR/logs"
STATE_DIR="$CLAUDE_DIR/state"
KNOWLEDGE_DIR="$CLAUDE_DIR/knowledge"

mkdir -p "$LOG_DIR" "$STATE_DIR"

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# --- Helpers ---

log_start() {
    local agent="$1"
    local log_file="$LOG_DIR/${agent}-$(date +%Y-%m-%d).log"
    echo "$(date '+%Y-%m-%d %H:%M:%S') — Starting $agent" >> "$log_file"
    echo "$log_file"
}

log_end() {
    local agent="$1"
    local log_file="$LOG_DIR/${agent}-$(date +%Y-%m-%d).log"
    echo "$(date '+%Y-%m-%d %H:%M:%S') — $agent complete" >> "$log_file"
}

check_claude() {
    if ! command -v claude &> /dev/null; then
        echo -e "${RED}Error: claude CLI not found${NC}"
        echo "Install: https://docs.anthropic.com/en/docs/claude-code"
        exit 1
    fi
}

# --- Agent runner ---

run_agent() {
    local agent="$1"
    shift
    local budget="${RHINO_BUDGET:-}"
    local prompt="$*"

    check_claude

    local log_file
    log_file="$(log_start "$agent")"

    local args=(
        -p
        --agent "$agent"
        --output-format stream-json
    )

    # Per-agent defaults
    case "$agent" in
        sweep)
            budget="${budget:-2.00}"
            [[ -z "$prompt" ]] && prompt="Run the sweep. Produce the brief. Classify all items. Do NOT auto-dispatch RED items — list them for human review."
            ;;
        scout)
            budget="${budget:-2.00}"
            [[ -z "$prompt" ]] && prompt="Run a standard scouting session. Follow all steps in order."
            ;;
        builder)
            [[ -z "$prompt" ]] && prompt="Auto-detect mode from context and proceed."
            ;;
        strategist)
            budget="${budget:-2.00}"
            [[ -z "$prompt" ]] && prompt="Run a full strategy assessment."
            ;;
        design-engineer)
            budget="${budget:-2.00}"
            [[ -z "$prompt" ]] && prompt="Auto-detect mode from context and proceed."
            ;;
    esac

    if [[ -n "$budget" ]]; then
        args+=(--max-budget-usd "$budget")
    fi

    echo -e "${BLUE}rhino ${agent}${NC} ${DIM}(budget: \$${budget:-unlimited})${NC}"
    echo -e "${DIM}logging to: $log_file${NC}"
    echo ""

    claude "${args[@]}" "$prompt" 2>> "$log_file" | tee -a "$log_file"

    log_end "$agent"
}

# --- Subcommands ---

cmd_sweep()   { run_agent sweep "$@"; }
cmd_scout()   { run_agent scout "$@"; }
cmd_build()   { run_agent builder "$@"; }
cmd_strategy(){ run_agent strategist "$@"; }
cmd_design()  { run_agent design-engineer "$@"; }

cmd_status() {
    echo -e "${BOLD}=== rhino status ===${NC}"
    echo ""

    # Sweep state
    local sweep_file="$STATE_DIR/sweep-latest.md"
    if [[ -f "$sweep_file" ]]; then
        local sweep_age
        sweep_age=$(( ( $(date +%s) - $(stat -f %m "$sweep_file" 2>/dev/null || stat -c %Y "$sweep_file" 2>/dev/null) ) / 3600 ))
        echo -e "${GREEN}Sweep:${NC} last run ${sweep_age}h ago"
        # Show first line (date header)
        head -1 "$sweep_file" | sed 's/^# /  /'
        # Show focus if present
        grep -A1 "^## Focus" "$sweep_file" 2>/dev/null | tail -1 | sed 's/^/  /' || true
    else
        echo -e "${YELLOW}Sweep:${NC} no state file found"
    fi
    echo ""

    # Knowledge freshness
    echo -e "${BOLD}Knowledge:${NC}"
    for kdir in "$KNOWLEDGE_DIR"/*/; do
        [[ ! -d "$kdir" ]] && continue
        local kname
        kname="$(basename "$kdir")"
        [[ "$kname" == "_template" ]] && continue
        local kfile="$kdir/knowledge.md"
        if [[ -f "$kfile" ]]; then
            local kage
            kage=$(( ( $(date +%s) - $(stat -f %m "$kfile" 2>/dev/null || stat -c %Y "$kfile" 2>/dev/null) ) / 86400 ))
            local freshness="${GREEN}fresh${NC}"
            (( kage > 7 )) && freshness="${YELLOW}${kage}d old${NC}"
            (( kage > 30 )) && freshness="${RED}stale (${kage}d)${NC}"
            local lines
            lines=$(wc -l < "$kfile" | tr -d ' ')
            echo -e "  $kname: ${freshness} (${lines} lines)"
        fi
    done
    echo ""

    # Intelligence layer
    echo -e "${BOLD}Intelligence:${NC}"

    # Portfolio
    local portfolio_file="$KNOWLEDGE_DIR/portfolio.json"
    if [[ -f "$portfolio_file" ]]; then
        if command -v jq &> /dev/null; then
            local proj_count
            proj_count=$(jq '.projects | length' "$portfolio_file" 2>/dev/null || echo "?")
            local last_review
            last_review=$(jq -r '.last_review // "never"' "$portfolio_file" 2>/dev/null || echo "unknown")
            echo -e "  Portfolio: ${proj_count} projects, last review: ${last_review}"
        else
            echo -e "  Portfolio: $(wc -l < "$portfolio_file" | tr -d ' ') lines (install jq for details)"
        fi
    else
        echo -e "  Portfolio: ${DIM}not initialized${NC}"
    fi

    # Landscape
    local landscape_file="$KNOWLEDGE_DIR/landscape.json"
    if [[ -f "$landscape_file" ]]; then
        if command -v jq &> /dev/null; then
            local pos_count
            pos_count=$(jq '.positions | length' "$landscape_file" 2>/dev/null || echo "?")
            local landscape_updated
            landscape_updated=$(jq -r '.updated // "never"' "$landscape_file" 2>/dev/null || echo "unknown")
            echo -e "  Landscape: ${pos_count} positions, updated: ${landscape_updated}"
        else
            echo -e "  Landscape: $(wc -l < "$landscape_file" | tr -d ' ') lines (install jq for details)"
        fi
    else
        echo -e "  Landscape: ${DIM}not initialized${NC}"
    fi

    # Taste
    local taste_file="$KNOWLEDGE_DIR/taste.jsonl"
    if [[ -f "$taste_file" ]]; then
        local taste_count
        taste_count=$(wc -l < "$taste_file" | tr -d ' ')
        echo -e "  Taste: ${taste_count} signals"
    else
        echo -e "  Taste: ${DIM}no signals recorded${NC}"
    fi
    echo ""

    # Recent logs
    echo -e "${BOLD}Recent activity:${NC}"
    local log_output
    log_output=$(for logfile in "$LOG_DIR"/*.log; do
        [[ ! -f "$logfile" ]] && continue
        local logname
        logname="$(basename "$logfile" .log)"
        local logdate
        logdate="$(echo "$logname" | grep -oE '[0-9]{4}-[0-9]{2}-[0-9]{2}' || echo "unknown")"
        local agent_name
        agent_name="$(echo "$logname" | sed 's/-[0-9]\{4\}-[0-9]\{2\}-[0-9]\{2\}$//')"
        echo "$logdate $agent_name"
    done | sort -r | head -5)
    if [[ -z "$log_output" ]]; then
        echo "  (no logs found)"
    else
        echo "$log_output" | while read -r line; do
            echo -e "  ${DIM}$line${NC}"
        done
    fi
    echo ""

    # Usage stats
    local usage_file="$LOG_DIR/usage.jsonl"
    if [[ -f "$usage_file" ]]; then
        local today
        today="$(date -u +%Y-%m-%d)"
        local today_count
        today_count=$(grep -c "$today" "$usage_file" 2>/dev/null || echo "0")
        local total_count
        total_count=$(wc -l < "$usage_file" | tr -d ' ')
        echo -e "${BOLD}Usage:${NC} ${today_count} tool calls today, ${total_count} total"
    fi
    echo ""

    # Focus drift detection
    if [[ -f "$usage_file" ]] && command -v jq &> /dev/null; then
        local week_ago
        week_ago="$(date -u -v-7d +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date -u -d '7 days ago' +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo "")"
        if [[ -n "$week_ago" ]]; then
            # Count edits per project in last 7 days
            local drift_data
            drift_data=$({ grep -E '"tool":"(Edit|Write)"' "$usage_file" || true; } | \
                awk -F'"' -v cutoff="$week_ago" '
                {
                    ts=""; proj=""
                    for (i=1; i<=NF; i++) {
                        if ($i == "ts") ts = $(i+2)
                        if ($i == "project") proj = $(i+2)
                    }
                    if (ts >= cutoff && proj != "") {
                        counts[proj]++
                        total++
                    }
                }
                END {
                    if (total > 0) {
                        for (p in counts) {
                            pct = int(counts[p] * 100 / total)
                            printf "  %s: %d%% (%d edits)\n", p, pct, counts[p]
                        }
                    }
                }
            ' 2>/dev/null)

            if [[ -n "$drift_data" ]]; then
                echo -e "${BOLD}Focus allocation (7d):${NC}"
                echo "$drift_data" | sort -t: -k2 -rn

                # Check for drift against portfolio focus
                if [[ -f "$portfolio_file" ]]; then
                    local primary_focus
                    primary_focus=$(jq -r '.focus.primary // empty' "$portfolio_file" 2>/dev/null)
                    if [[ -n "$primary_focus" ]]; then
                        local primary_pct
                        primary_pct=$(echo "$drift_data" | grep -F "$primary_focus" | grep -oE '[0-9]+%' | head -1 | tr -d '%')
                        if [[ -n "$primary_pct" && "$primary_pct" -lt 50 ]]; then
                            echo -e "  ${YELLOW}DRIFT:${NC} ${primary_focus} is primary focus but only ${primary_pct}% of edits"
                        fi
                    fi
                fi
                echo ""
            fi
        fi
    fi

    # Code style summary (separate from taste)
    local style_file="$LOG_DIR/code-style.jsonl"
    if [[ -f "$style_file" ]]; then
        local style_count
        style_count=$(wc -l < "$style_file" | tr -d ' ')
        echo -e "${BOLD}Code style:${NC} ${style_count} observations (auto-detected formatting patterns)"
    fi
}

cmd_backup() {
    echo -e "${BOLD}=== rhino backup ===${NC}"

    local backup_base="$CLAUDE_DIR/backups"
    local timestamp
    timestamp="$(date +%Y%m%d-%H%M%S)"
    local backup_dir="$backup_base/knowledge-$timestamp"

    mkdir -p "$backup_dir"

    if [[ -d "$KNOWLEDGE_DIR" ]]; then
        cp -r "$KNOWLEDGE_DIR"/* "$backup_dir/" 2>/dev/null || true
        echo -e "${GREEN}Knowledge backed up to:${NC}"
        echo "  $backup_dir"

        # Count what was backed up
        local file_count
        file_count=$(find "$backup_dir" -type f | wc -l | tr -d ' ')
        echo -e "  ${file_count} files"
    else
        echo -e "${YELLOW}No knowledge directory found${NC}"
    fi

    # Also back up state
    if [[ -d "$STATE_DIR" ]]; then
        cp -r "$STATE_DIR" "$backup_dir/_state" 2>/dev/null || true
        echo -e "  State files included"
    fi

    # Prune old backups (keep last 10)
    local backup_count
    backup_count=$(ls -d "$backup_base"/knowledge-* 2>/dev/null | wc -l | tr -d ' ')
    if (( backup_count > 10 )); then
        ls -dt "$backup_base"/knowledge-* | tail -n +11 | xargs rm -rf
        echo -e "  ${DIM}Pruned old backups (keeping last 10)${NC}"
    fi
}

cmd_doctor() {
    echo -e "${BOLD}=== rhino doctor ===${NC}"
    echo ""
    local issues=0

    # Check claude CLI
    if command -v claude &> /dev/null; then
        echo -e "${GREEN}[OK]${NC} claude CLI found: $(which claude)"
    else
        echo -e "${RED}[FAIL]${NC} claude CLI not found"
        ((issues++))
    fi

    # Check symlinks
    echo ""
    echo -e "${BOLD}Symlinks:${NC}"
    for agent in "$CLAUDE_DIR"/agents/*.md; do
        [[ ! -e "$agent" ]] && continue
        if [[ -L "$agent" ]]; then
            local target
            target="$(readlink "$agent")"
            if [[ -f "$target" ]]; then
                echo -e "  ${GREEN}[OK]${NC} $(basename "$agent")"
            else
                echo -e "  ${RED}[BROKEN]${NC} $(basename "$agent") → $target"
                ((issues++))
            fi
        fi
    done

    # Check MCP server
    echo ""
    echo -e "${BOLD}MCP Server:${NC}"
    if [[ -f "$RHINO_DIR/src/mcp-server/index.ts" ]]; then
        if [[ -d "$RHINO_DIR/src/mcp-server/node_modules" ]]; then
            echo -e "  ${GREEN}[OK]${NC} rhino-state MCP server installed"
        else
            echo -e "  ${YELLOW}[WARN]${NC} rhino-state MCP server not installed (run: cd src/mcp-server && npm install)"
            ((issues++))
        fi
    else
        echo -e "  ${DIM}[SKIP]${NC} MCP server not present"
    fi

    # Check config.json for MCP entry
    if [[ -f "$CLAUDE_DIR/config.json" ]]; then
        if grep -q "rhino-state" "$CLAUDE_DIR/config.json" 2>/dev/null; then
            echo -e "  ${GREEN}[OK]${NC} rhino-state registered in config.json"
        else
            echo -e "  ${YELLOW}[WARN]${NC} rhino-state not in config.json"
        fi
    fi

    # Check LaunchAgents
    echo ""
    echo -e "${BOLD}LaunchAgents:${NC}"
    for label in com.claude-os.sweep com.claude-os.scout; do
        if launchctl list "$label" &>/dev/null; then
            echo -e "  ${GREEN}[OK]${NC} $label loaded"
        else
            echo -e "  ${YELLOW}[WARN]${NC} $label not loaded"
        fi
    done

    # Check stale state files
    echo ""
    echo -e "${BOLD}State files:${NC}"
    local stale_count=0
    for state_file in "$STATE_DIR"/*; do
        [[ ! -f "$state_file" ]] && continue
        local file_age
        file_age=$(( ( $(date +%s) - $(stat -f %m "$state_file" 2>/dev/null || stat -c %Y "$state_file" 2>/dev/null) ) / 86400 ))
        if (( file_age > 7 )); then
            echo -e "  ${YELLOW}[STALE]${NC} $(basename "$state_file") (${file_age}d old)"
            ((stale_count++))
        else
            echo -e "  ${GREEN}[OK]${NC} $(basename "$state_file") (${file_age}d old)"
        fi
    done
    [[ $stale_count -gt 0 ]] && echo -e "  ${DIM}Run sweep to clean stale state${NC}"

    # Check knowledge freshness
    echo ""
    echo -e "${BOLD}Knowledge health:${NC}"
    for kdir in "$KNOWLEDGE_DIR"/*/; do
        [[ ! -d "$kdir" ]] && continue
        local kname
        kname="$(basename "$kdir")"
        [[ "$kname" == "_template" ]] && continue
        local kfile="$kdir/knowledge.md"
        if [[ -f "$kfile" ]]; then
            local ksize
            ksize=$(wc -c < "$kfile" | tr -d ' ')
            local klines
            klines=$(wc -l < "$kfile" | tr -d ' ')
            if (( klines > 200 )); then
                echo -e "  ${YELLOW}[WARN]${NC} $kname/knowledge.md is ${klines} lines (max recommended: 200)"
                ((issues++))
            else
                echo -e "  ${GREEN}[OK]${NC} $kname/knowledge.md (${klines} lines)"
            fi
        fi
    done

    # Check API server
    echo ""
    echo -e "${BOLD}API Server:${NC}"
    if [[ -f "$RHINO_DIR/src/api-server/index.ts" ]]; then
        if [[ -d "$RHINO_DIR/src/api-server/node_modules" ]]; then
            echo -e "  ${GREEN}[OK]${NC} API server installed"
        else
            echo -e "  ${YELLOW}[WARN]${NC} API server not installed (run: cd src/api-server && npm install)"
        fi
    else
        echo -e "  ${DIM}[SKIP]${NC} API server not present"
    fi

    echo ""
    if (( issues == 0 )); then
        echo -e "${GREEN}${BOLD}All checks passed${NC}"
    else
        echo -e "${YELLOW}${BOLD}${issues} issue(s) found${NC}"
    fi
}

cmd_taste() {
    local subcommand="${1:-summary}"

    local taste_file="$KNOWLEDGE_DIR/taste.jsonl"
    local style_file="$LOG_DIR/code-style.jsonl"

    case "$subcommand" in
        summary)
            echo -e "${BOLD}=== rhino taste ===${NC}"
            echo ""
            echo -e "${DIM}Taste = macro judgment (what to build, kill, prioritize)${NC}"
            echo -e "${DIM}Code style = formatting (camelCase, semicolons) — separate concern${NC}"
            echo ""

            # Taste signals
            if [[ -f "$taste_file" ]]; then
                echo -e "${BOLD}Judgment signals:${NC}"
                if command -v jq &> /dev/null; then
                    jq -r '"\(.strength)/\(.domain): \(.signal)"' "$taste_file" 2>/dev/null | sort | while read -r line; do
                        local str="${line%%/*}"
                        local rest="${line#*/}"
                        case "$str" in
                            strong)   echo -e "  ${GREEN}[strong]${NC} $rest" ;;
                            moderate) echo -e "  ${YELLOW}[moderate]${NC} $rest" ;;
                            weak)     echo -e "  ${DIM}[weak]${NC} $rest" ;;
                        esac
                    done
                else
                    local count
                    count=$(wc -l < "$taste_file" | tr -d ' ')
                    echo "  $count signals (install jq for details)"
                fi
            else
                echo -e "  ${DIM}No taste signals yet — agents record these as they observe your decisions${NC}"
            fi
            echo ""

            # Code style (separate from taste)
            if [[ -f "$style_file" ]]; then
                echo -e "${BOLD}Code style (auto-detected, NOT taste):${NC}"
                local total_styles
                total_styles=$(wc -l < "$style_file" | tr -d ' ')
                echo -e "  ${total_styles} observations"

                if command -v jq &> /dev/null; then
                    jq -r '.s[]' "$style_file" 2>/dev/null | sort | uniq -c | sort -rn | head -5 | while read -r count pattern; do
                        echo -e "  ${DIM}${count}x${NC} $pattern"
                    done
                fi
            fi
            ;;
        export)
            echo -e "${BOLD}=== taste export ===${NC}"

            if [[ ! -f "$taste_file" && ! -f "$style_file" ]]; then
                echo -e "${YELLOW}Nothing to export${NC}"
                return 1
            fi

            local export_file="$HOME/taste-profile-$(date +%Y%m%d).json"

            # Build export via node if MCP server is available, otherwise basic
            if command -v jq &> /dev/null; then
                local signals="[]"
                if [[ -f "$taste_file" ]]; then
                    signals=$(jq -s '.' "$taste_file" 2>/dev/null || echo "[]")
                fi

                local styles="{}"
                if [[ -f "$style_file" ]]; then
                    styles=$(jq -r '.s[]' "$style_file" 2>/dev/null | sort | uniq -c | sort -rn | awk '{printf "\"%s\": %d,\n", $2, $1}' | sed '$ s/,$//' | { echo "{"; cat; echo "}"; })
                fi

                jq -n \
                    --argjson signals "$signals" \
                    --argjson code_style "$styles" \
                    '{version: "1.0", exported: now | todate, taste_signals: $signals, code_style: $code_style}' \
                    > "$export_file" 2>/dev/null

                echo -e "${GREEN}Exported to:${NC} $export_file"
                echo -e "  Judgment signals: $(echo "$signals" | jq 'length')"
                echo -e "  Code style patterns: $(echo "$styles" | jq 'keys | length') categories"
            else
                echo -e "${YELLOW}jq required for export${NC}"
                return 1
            fi
            ;;
        *)
            echo -e "${RED}Unknown taste subcommand: $subcommand${NC}"
            echo "Usage: rhino taste [summary|export]"
            return 1
            ;;
    esac
}

cmd_capture() {
    # NOTE: `claude -p` starts a NEW session with NO memory of the previous one.
    # So we capture from observable artifacts: git diff, usage logs, plan state.
    # This gives real data, not hallucinated session summaries.

    local project_name
    project_name="$(basename "$(pwd)")"
    local sessions_dir="$KNOWLEDGE_DIR/sessions"
    mkdir -p "$sessions_dir"
    local target_file="$sessions_dir/${project_name}.md"
    local today
    today="$(date +%Y-%m-%d)"

    echo -e "${BLUE}rhino capture${NC} — extracting session artifacts for ${BOLD}${project_name}${NC}"

    local capture=""

    # 1. Git activity (what actually changed)
    if git rev-parse --is-inside-work-tree &>/dev/null; then
        local recent_commits
        recent_commits=$(git log --oneline -10 --since="6 hours ago" 2>/dev/null || true)
        if [[ -n "$recent_commits" ]]; then
            capture+="### Commits
$recent_commits
"
        fi

        local uncommitted
        uncommitted=$(git diff --stat 2>/dev/null | tail -5)
        if [[ -n "$uncommitted" ]]; then
            capture+="### Uncommitted changes
$uncommitted
"
        fi
    fi

    # 2. Tool activity (what tools were used, on what)
    local usage_file="$LOG_DIR/usage.jsonl"
    if [[ -f "$usage_file" ]] && command -v jq &>/dev/null; then
        local six_hours_ago
        six_hours_ago="$(date -u -v-6H +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date -u -d '6 hours ago' +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo "")"
        if [[ -n "$six_hours_ago" ]]; then
            local edit_count
            edit_count=$({ grep -E '"tool":"(Edit|Write)"' "$usage_file" || true; } | \
                awk -F'"' -v cutoff="$six_hours_ago" '
                {
                    for (i=1; i<=NF; i++) {
                        if ($i == "ts") { ts = $(i+2); break }
                    }
                    if (ts >= cutoff) count++
                }
                END { print count+0 }
            ' 2>/dev/null)
            if (( edit_count > 0 )); then
                capture+="### Activity
${edit_count} edits in last 6h
"
            fi
        fi
    fi

    # 3. Active plan state
    local plan_file="$CLAUDE_DIR/plans/active-plan.md"
    if [[ -f "$plan_file" ]]; then
        local plan_title
        plan_title=$(head -3 "$plan_file" | grep -E '^#' | head -1 || echo "Active plan exists")
        capture+="### Plan
$plan_title
"
    fi

    # 4. Taste signals recorded today
    local taste_file="$KNOWLEDGE_DIR/taste.jsonl"
    if [[ -f "$taste_file" ]]; then
        local today_taste
        today_taste=$(grep "$today" "$taste_file" 2>/dev/null | head -5)
        if [[ -n "$today_taste" ]] && command -v jq &>/dev/null; then
            local taste_summary
            taste_summary=$(echo "$today_taste" | jq -r '"[\(.domain)] \(.signal)"' 2>/dev/null)
            if [[ -n "$taste_summary" ]]; then
                capture+="### Taste signals recorded
$taste_summary
"
            fi
        fi
    fi

    if [[ -z "$capture" ]]; then
        echo -e "${YELLOW}Nothing to capture${NC} — no recent git activity, edits, or taste signals"
        return 0
    fi

    # Write to session file
    {
        echo ""
        echo "## $today — $project_name"
        echo "$capture"
    } >> "$target_file"

    echo -e "${GREEN}Captured to:${NC} $target_file"

    # Prune entries older than 60 days
    if [[ -f "$target_file" ]]; then
        local sixty_days_ago
        sixty_days_ago=$(date -v-60d +%Y-%m-%d 2>/dev/null || date -d '60 days ago' +%Y-%m-%d 2>/dev/null || echo "")
        if [[ -n "$sixty_days_ago" ]]; then
            local tmpfile
            tmpfile=$(mktemp)
            awk -v cutoff="$sixty_days_ago" '
                BEGIN { printing = 1 }
                /^## [0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]/ {
                    dt = substr($2, 1, 10)
                    printing = (dt >= cutoff)
                }
                printing { print }
            ' "$target_file" > "$tmpfile" && mv "$tmpfile" "$target_file" || rm -f "$tmpfile"
        fi
    fi
}

cmd_visuals() {
    local target_dir="${1:-.}"
    local output_dir="$target_dir/docs/evals"

    # Find history file — project-local first, then global
    local history_file=""
    for hp in "$target_dir/.claude/evals/reports/history.jsonl" "$target_dir/docs/evals/reports/history.jsonl" "$CLAUDE_DIR/evals/reports/history.jsonl"; do
        if [[ -f "$hp" ]]; then
            history_file="$hp"
            break
        fi
    done

    if [[ -z "$history_file" ]]; then
        echo -e "${YELLOW}No eval history found.${NC} Run /eval after building features."
        return 0
    fi

    if ! command -v jq &>/dev/null; then
        echo -e "${RED}jq required for visuals generation${NC}"
        return 1
    fi

    mkdir -p "$output_dir"

    # Compute stats
    local total ship fixes blocked ceiling_avg
    total=$(wc -l < "$history_file" | tr -d ' ')
    ship=$(grep -c '"verdict":"SHIP"' "$history_file" || true)
    fixes=$(grep -c 'SHIP WITH' "$history_file" || true)
    blocked=$(grep -c '"BLOCKED"' "$history_file" || true)
    local ship_rate=0
    if [[ "$total" -gt 0 ]]; then
        ship_rate=$(( ship * 100 / total ))
    fi

    ceiling_avg=$(jq -r '.ceiling // empty' "$history_file" 2>/dev/null | \
        awk '{ sum += $1; count++ } END { if (count > 0) printf "%.2f", sum/count; else print "0" }')

    # Determine badge colors (use || true to avoid set -e failures)
    local ship_color="e74c3c"
    [[ "$ship_rate" -ge 50 ]] && ship_color="f39c12" || true
    [[ "$ship_rate" -ge 70 ]] && ship_color="2ecc71" || true

    local ceil_color="e74c3c"
    local ceil_cmp
    ceil_cmp=$(awk "BEGIN { print ($ceiling_avg >= 0.5) }" 2>/dev/null || echo "0")
    [[ "$ceil_cmp" == "1" ]] && ceil_color="f39c12" || true
    ceil_cmp=$(awk "BEGIN { print ($ceiling_avg >= 0.7) }" 2>/dev/null || echo "0")
    [[ "$ceil_cmp" == "1" ]] && ceil_color="2ecc71" || true

    # Generate SVG badges
    cat > "$output_dir/ship-rate.svg" << SVGEOF
<svg xmlns="http://www.w3.org/2000/svg" width="140" height="20">
  <rect width="70" height="20" fill="#555" rx="3"/>
  <rect x="70" width="70" height="20" fill="#${ship_color}" rx="3"/>
  <rect width="140" height="20" fill="url(#g)" rx="3"/>
  <g fill="#fff" text-anchor="middle" font-family="monospace" font-size="11">
    <text x="35" y="14">ship rate</text>
    <text x="105" y="14">${ship_rate}%</text>
  </g>
</svg>
SVGEOF

    cat > "$output_dir/ceiling-avg.svg" << SVGEOF
<svg xmlns="http://www.w3.org/2000/svg" width="140" height="20">
  <rect width="70" height="20" fill="#555" rx="3"/>
  <rect x="70" width="70" height="20" fill="#${ceil_color}" rx="3"/>
  <rect width="140" height="20" fill="url(#g)" rx="3"/>
  <g fill="#fff" text-anchor="middle" font-family="monospace" font-size="11">
    <text x="35" y="14">ceiling</text>
    <text x="105" y="14">${ceiling_avg}</text>
  </g>
</svg>
SVGEOF

    cat > "$output_dir/total-evals.svg" << SVGEOF
<svg xmlns="http://www.w3.org/2000/svg" width="130" height="20">
  <rect width="60" height="20" fill="#555" rx="3"/>
  <rect x="60" width="70" height="20" fill="#2196f3" rx="3"/>
  <rect width="130" height="20" fill="url(#g)" rx="3"/>
  <g fill="#fff" text-anchor="middle" font-family="monospace" font-size="11">
    <text x="30" y="14">evals</text>
    <text x="95" y="14">${total}</text>
  </g>
</svg>
SVGEOF

    # Generate markdown summary
    local recent
    recent=$(tail -10 "$history_file" | jq -r 'select(.type != "experiment") | "| \(.date) | \(.feature) | \(.verdict) | \(.ceiling // "—") | \(.perspectives // "—") |"' 2>/dev/null)

    local gaps
    gaps=$(jq -r '(.ceiling_gaps // .top_gaps // [])[]' "$history_file" 2>/dev/null | sort | uniq -c | sort -rn | head -5 | awk '{$1=$1; count=$1; $1=""; sub(/^ /, ""); printf "| %s | %dx |\n", $0, count}')

    # Experiment data
    local exp_section=""
    local exp_entries
    exp_entries=$(grep '"type":"experiment"' "$history_file" 2>/dev/null || true)
    if [[ -n "$exp_entries" ]]; then
        local exp_rows
        exp_rows=$(echo "$exp_entries" | jq -r '"| \(.date) | \(.dimension) | \(.start_score) → \(.best_score) | \(.kept)/\(.experiments) | \(.top_win // "—") |"' 2>/dev/null)
        exp_section="
## Experiments

| Date | Dimension | Progress | Kept | Top Win |
|------|-----------|----------|------|---------|
${exp_rows}
"
    fi

    # Also check for experiment TSVs in the project
    local exp_tsv_section=""
    for exp_dir in "$target_dir/.claude/experiments" "$target_dir/docs/experiments"; do
        if [[ -d "$exp_dir" ]]; then
            local tsv_rows=""
            for tsv in "$exp_dir"/*.tsv; do
                [[ -f "$tsv" ]] || continue
                local ename
                ename=$(basename "$tsv" .tsv)
                local etotal ekept ediscarded
                etotal=$(tail -n +2 "$tsv" | grep -cv '^---\|^$' 2>/dev/null || echo "0")
                ekept=$(grep -c 'keep' "$tsv" 2>/dev/null || echo "0")
                ediscarded=$(grep -c 'discard' "$tsv" 2>/dev/null || echo "0")
                local estart ebest
                estart=$(awk -F'\t' 'NR==2 && $2 != "---" {print $2}' "$tsv" 2>/dev/null || echo "?")
                ebest=$(awk -F'\t' '$4=="keep" {print $2}' "$tsv" 2>/dev/null | sort -n | tail -1)
                [[ -z "$ebest" ]] && ebest="$estart"

                # Build bar chart for kept experiments
                local bar=""
                local bar_entries
                bar_entries=$(awk -F'\t' 'NR>1 && $2 != "---" && $4 != "" {
                    if ($4 == "keep") printf "█"
                    else if ($4 == "discard") printf "░"
                    else if ($4 == "crash") printf "x"
                }' "$tsv" 2>/dev/null)
                bar="$bar_entries"

                tsv_rows="${tsv_rows}| ${ename} | ${estart} → ${ebest} | ${ekept}/${etotal} | \`${bar}\` |
"
            done

            if [[ -n "$tsv_rows" ]]; then
                exp_tsv_section="
## Active Experiments

| Experiment | Progress | Kept | History |
|------------|----------|------|---------|
${tsv_rows}"
            fi
            break
        fi
    done

    # Product eval scores (if any)
    local product_section=""
    local product_entry
    product_entry=$(grep '"type":"product-eval"' "$history_file" 2>/dev/null | tail -1 || true)
    if [[ -n "$product_entry" ]]; then
        local p_overall p_4sec p_empty p_create p_day3 p_identity p_escape p_verdict
        p_overall=$(echo "$product_entry" | jq -r '.overall // "?"' 2>/dev/null)
        p_4sec=$(echo "$product_entry" | jq -r '.four_second // "?"' 2>/dev/null)
        p_empty=$(echo "$product_entry" | jq -r '.empty_room // "?"' 2>/dev/null)
        p_create=$(echo "$product_entry" | jq -r '.creation_distribution // "?"' 2>/dev/null)
        p_day3=$(echo "$product_entry" | jq -r '.day3_return // "?"' 2>/dev/null)
        p_identity=$(echo "$product_entry" | jq -r '.identity // "?"' 2>/dev/null)
        p_escape=$(echo "$product_entry" | jq -r '.escape_velocity // "?"' 2>/dev/null)
        p_verdict=$(echo "$product_entry" | jq -r '.verdict // "?"' 2>/dev/null)

        # Build bar function
        make_bar() {
            local score="$1" width=30
            local filled
            filled=$(awk "BEGIN { printf \"%d\", $score * $width }" 2>/dev/null || echo "1")
            [[ "$filled" -lt 1 ]] && filled=1
            local empty=$(( width - filled ))
            printf '%*s' "$filled" '' | tr ' ' '█'
            printf '%*s' "$empty" '' | tr ' ' '░'
        }

        product_section="
## Product Eval — ${p_verdict} (${p_overall}/1.0)

\`\`\`
4-Second Test         $(make_bar "$p_4sec")  ${p_4sec}
Empty Room            $(make_bar "$p_empty")  ${p_empty}
Creation→Distribution $(make_bar "$p_create")  ${p_create}
Day 3 Return          $(make_bar "$p_day3")  ${p_day3}
Identity              $(make_bar "$p_identity")  ${p_identity}
Escape Velocity       $(make_bar "$p_escape")  ${p_escape}
\`\`\`
"
    fi

    mkdir -p "$output_dir/badges"

    cat > "$output_dir/ship-rate.svg" << SVGEOF
<svg xmlns="http://www.w3.org/2000/svg" width="140" height="20">
  <rect width="70" height="20" fill="#555" rx="3"/>
  <rect x="70" width="70" height="20" fill="#${ship_color}" rx="3"/>
  <g fill="#fff" text-anchor="middle" font-family="monospace" font-size="11">
    <text x="35" y="14">ship rate</text>
    <text x="105" y="14">${ship_rate}%</text>
  </g>
</svg>
SVGEOF

    cat > "$output_dir/ceiling-avg.svg" << SVGEOF
<svg xmlns="http://www.w3.org/2000/svg" width="140" height="20">
  <rect width="70" height="20" fill="#555" rx="3"/>
  <rect x="70" width="70" height="20" fill="#${ceil_color}" rx="3"/>
  <g fill="#fff" text-anchor="middle" font-family="monospace" font-size="11">
    <text x="35" y="14">ceiling</text>
    <text x="105" y="14">${ceiling_avg}</text>
  </g>
</svg>
SVGEOF

    cat > "$output_dir/total-evals.svg" << SVGEOF
<svg xmlns="http://www.w3.org/2000/svg" width="130" height="20">
  <rect width="60" height="20" fill="#555" rx="3"/>
  <rect x="60" width="70" height="20" fill="#2196f3" rx="3"/>
  <g fill="#fff" text-anchor="middle" font-family="monospace" font-size="11">
    <text x="30" y="14">evals</text>
    <text x="95" y="14">${total}</text>
  </g>
</svg>
SVGEOF

    # Product score badge (if product eval exists)
    if [[ -n "$product_entry" ]]; then
        local p_color="e74c3c"
        local p_cmp
        p_cmp=$(awk "BEGIN { print ($p_overall >= 0.5) }" 2>/dev/null || echo "0")
        [[ "$p_cmp" == "1" ]] && p_color="f39c12" || true
        p_cmp=$(awk "BEGIN { print ($p_overall >= 0.7) }" 2>/dev/null || echo "0")
        [[ "$p_cmp" == "1" ]] && p_color="2ecc71" || true

        cat > "$output_dir/badges/product-score.svg" << SVGEOF
<svg xmlns="http://www.w3.org/2000/svg" width="160" height="20">
  <rect width="90" height="20" fill="#555" rx="3"/>
  <rect x="90" width="70" height="20" fill="#${p_color}" rx="3"/>
  <g fill="#fff" text-anchor="middle" font-family="monospace" font-size="11">
    <text x="45" y="14">product eval</text>
    <text x="125" y="14">${p_overall}/1.0</text>
  </g>
</svg>
SVGEOF
    fi

    cat > "$output_dir/EVAL-RESULTS.md" << MDEOF
# AI Eval Results

![Ship Rate](ship-rate.svg) ![Ceiling](ceiling-avg.svg) ![Total](total-evals.svg)
${product_section}
## Summary

| Metric | Value |
|--------|-------|
| Total evals | ${total} |
| Ship rate | ${ship_rate}% |
| Ship | ${ship} |
| Ship with fixes | ${fixes} |
| Blocked | ${blocked} |
| Ceiling avg | ${ceiling_avg} |
${exp_section}${exp_tsv_section}
## Feature Evals

| Date | Feature | Verdict | Ceiling | Perspectives |
|------|---------|---------|---------|-------------|
${recent}

## Top Ceiling Gaps

| Gap | Frequency |
|-----|-----------|
${gaps}

---
*Generated by [rhino-os](https://github.com/laneyfraass/rhino-os) · $(date +%Y-%m-%d)*
MDEOF

    echo -e "${GREEN}Generated visuals:${NC}"
    echo "  $output_dir/ship-rate.svg"
    echo "  $output_dir/ceiling-avg.svg"
    echo "  $output_dir/total-evals.svg"
    echo "  $output_dir/EVAL-RESULTS.md"
    [[ -n "$product_entry" ]] && echo "  $output_dir/badges/product-score.svg"
    echo ""
    echo "Add to your README:"
    echo "  ![Ship Rate](docs/evals/ship-rate.svg) ![Ceiling](docs/evals/ceiling-avg.svg)"
}

cmd_init_eval() {
    local target_dir="${1:-.}"

    if [[ ! -d "$target_dir/.git" ]]; then
        echo -e "${RED}Not a git repo: $target_dir${NC}"
        return 1
    fi

    local workflow_dir="$target_dir/.github/workflows"
    mkdir -p "$workflow_dir"

    local source="$RHINO_DIR/templates/github/ai-eval.yml"
    local dest="$workflow_dir/ai-eval.yml"

    if [[ -f "$dest" ]]; then
        echo -e "${YELLOW}AI eval workflow already exists:${NC} $dest"
        echo "Overwrite? (y/n)"
        read -r answer
        [[ "$answer" != "y" ]] && return 0
    fi

    cp "$source" "$dest"
    echo -e "${GREEN}Installed AI eval workflow:${NC} $dest"
    echo ""
    echo -e "${BOLD}Next steps:${NC}"
    echo "  1. Run: claude setup-token"
    echo "     Copy the token output"
    echo "  2. Add CLAUDE_CODE_OAUTH_TOKEN to your repo secrets"
    echo "     (Settings → Secrets → Actions → New repository secret)"
    echo "  3. Use builder plan mode to generate .claude/evals/[feature].yml"
    echo "  4. Open a PR — eval runs automatically and posts results"
    echo ""
    echo "  No API key needed — uses your Claude Code auth."
}

cmd_report() {
    echo -e "${BOLD}=== rhino report ===${NC}"
    echo ""

    local history_file="$CLAUDE_DIR/evals/reports/history.jsonl"

    if [[ ! -f "$history_file" ]]; then
        echo -e "${YELLOW}No eval history found.${NC}"
        echo "Run /eval after building features to populate this."
        return 0
    fi

    local total
    total=$(wc -l < "$history_file" | tr -d ' ')
    echo -e "${BOLD}Total evals:${NC} $total"
    echo ""

    if ! command -v jq &>/dev/null; then
        echo "Install jq for detailed reports: brew install jq"
        echo ""
        echo -e "${BOLD}Recent evals:${NC}"
        tail -10 "$history_file"
        return 0
    fi

    # Verdicts breakdown
    local ship blocked fixes
    ship=$(grep -c '"verdict":"SHIP"' "$history_file" 2>/dev/null || echo "0")
    fixes=$(grep -c '"SHIP.WITH' "$history_file" 2>/dev/null || echo "0")
    blocked=$(grep -c '"BLOCKED"' "$history_file" 2>/dev/null || echo "0")
    echo -e "${BOLD}Verdicts:${NC}"
    echo -e "  ${GREEN}SHIP:${NC} $ship"
    echo -e "  ${YELLOW}SHIP WITH FIXES:${NC} $fixes"
    echo -e "  ${RED}BLOCKED:${NC} $blocked"
    echo ""

    # First-pass rate (SHIP on first eval per feature)
    if (( total > 0 )); then
        local first_pass_pct=$(( ship * 100 / total ))
        echo -e "${BOLD}First-pass ship rate:${NC} ${first_pass_pct}%"
        echo ""
    fi

    # Avg perspective score
    local avg_perspectives
    avg_perspectives=$(jq -r '.perspectives // empty' "$history_file" 2>/dev/null | \
        awk '{ sum += $1; count++ } END { if (count > 0) printf "%.2f", sum/count; else print "n/a" }')
    echo -e "${BOLD}Avg perspective score:${NC} $avg_perspectives / 1.0"
    echo ""

    # Last 30 days
    local thirty_ago
    thirty_ago="$(date -v-30d +%Y-%m-%d 2>/dev/null || date -d '30 days ago' +%Y-%m-%d 2>/dev/null || echo "")"
    if [[ -n "$thirty_ago" ]]; then
        local recent_count
        recent_count=$(jq -r --arg cutoff "$thirty_ago" 'select(.date >= $cutoff)' "$history_file" 2>/dev/null | grep -c '"date"' || echo "0")
        echo -e "${BOLD}Last 30 days:${NC} $recent_count evals"
    fi
    echo ""

    # Recent history
    echo -e "${BOLD}Recent evals:${NC}"
    tail -10 "$history_file" | jq -r '
        "\(.date) \(.feature) → \(.verdict) (perspectives: \(.perspectives // "n/a"))"
    ' 2>/dev/null | while read -r line; do
        if echo "$line" | grep -q "SHIP WITH"; then
            echo -e "  ${YELLOW}$line${NC}"
        elif echo "$line" | grep -q "BLOCKED"; then
            echo -e "  ${RED}$line${NC}"
        elif echo "$line" | grep -q "SHIP"; then
            echo -e "  ${GREEN}$line${NC}"
        else
            echo "  $line"
        fi
    done
}

cmd_experiments() {
    echo -e "${BOLD}=== experiments ===${NC}"
    echo ""

    local project_dir="${1:-.}"

    # Find experiment TSVs — check project-local paths
    local exp_dir=""
    for candidate in "$project_dir/.claude/experiments" "$project_dir/docs/experiments"; do
        if [[ -d "$candidate" ]]; then
            exp_dir="$candidate"
            break
        fi
    done

    # Also check for experiment branches
    local exp_branches=""
    if git -C "$project_dir" rev-parse --is-inside-work-tree &>/dev/null 2>&1; then
        exp_branches=$(git -C "$project_dir" branch -a 2>/dev/null | grep 'exp/' | sed 's/^[* ]*//' | head -20 || true)
    fi

    if [[ -z "$exp_dir" && -z "$exp_branches" ]]; then
        echo -e "${DIM}No experiments found.${NC}"
        echo "Run /experiment [dimension] to start autonomous iteration."
        return 0
    fi

    # Show experiment branches
    if [[ -n "$exp_branches" ]]; then
        echo -e "${BOLD}Experiment branches:${NC}"
        echo "$exp_branches" | while read -r branch; do
            local branch_name="${branch##*/}"
            # Count commits on this branch vs main
            local commit_count
            commit_count=$(git -C "$project_dir" rev-list --count "main..$branch" 2>/dev/null || echo "?")
            echo -e "  ${BLUE}$branch${NC} (${commit_count} commits)"
        done
        echo ""
    fi

    # Show experiment logs
    if [[ -n "$exp_dir" ]]; then
        echo -e "${BOLD}Experiment logs:${NC}"
        for tsv in "$exp_dir"/*.tsv; do
            [[ -f "$tsv" ]] || continue
            local name
            name=$(basename "$tsv" .tsv)
            local total kept discarded
            total=$(tail -n +2 "$tsv" | grep -cv '^---\|^$' 2>/dev/null || echo "0")
            kept=$(grep -c 'keep' "$tsv" 2>/dev/null || echo "0")
            discarded=$(grep -c 'discard' "$tsv" 2>/dev/null || echo "0")

            # Get first and last scores
            local start_score best_score
            start_score=$(awk -F'\t' 'NR==2 && $2 != "---" {print $2}' "$tsv" 2>/dev/null)
            best_score=$(awk -F'\t' '$4=="keep" {print $2}' "$tsv" 2>/dev/null | sort -n | tail -1)

            # Color based on progress
            local score_display=""
            if [[ -n "$start_score" && -n "$best_score" ]]; then
                score_display="${start_score} → ${best_score}"
            fi

            echo -e "  ${YELLOW}${name}${NC}: ${total} experiments (${GREEN}${kept} kept${NC}, ${RED}${discarded} discarded${NC}) ${score_display}"

            # Show last 3 entries
            tail -3 "$tsv" | while IFS=$'\t' read -r commit score delta status desc; do
                [[ "$commit" == "commit" || "$commit" == "---" ]] && continue
                local color="$DIM"
                [[ "$status" == "keep" ]] && color="$GREEN"
                [[ "$status" == "discard" ]] && color="$RED"
                [[ "$status" == "crash" ]] && color="$RED"
                echo -e "    ${color}${status}${NC} ${delta} ${DIM}${desc}${NC}"
            done
            echo ""
        done
    fi

    # Show experiment entries from history.jsonl
    local history_file=""
    for hp in "$project_dir/.claude/evals/reports/history.jsonl" "$project_dir/docs/evals/reports/history.jsonl"; do
        if [[ -f "$hp" ]]; then
            history_file="$hp"
            break
        fi
    done

    if [[ -n "$history_file" ]] && command -v jq &>/dev/null; then
        local exp_entries
        exp_entries=$(grep '"type":"experiment"' "$history_file" 2>/dev/null)
        if [[ -n "$exp_entries" ]]; then
            echo -e "${BOLD}Completed experiments:${NC}"
            echo "$exp_entries" | jq -r '"  \(.date) \(.dimension): \(.start_score) → \(.best_score) (\(.kept)/\(.experiments) kept) — \(.top_win // "n/a")"' 2>/dev/null
            echo ""
        fi
    fi
}

cmd_serve() {
    check_claude

    local port="${RHINO_PORT:-7890}"
    echo -e "${BLUE}rhino serve${NC} — starting API server on port $port"

    if [[ ! -f "$RHINO_DIR/src/api-server/index.ts" ]]; then
        echo -e "${RED}Error: API server not found at src/api-server/index.ts${NC}"
        echo "Run install.sh to set up the API server."
        exit 1
    fi

    if [[ ! -d "$RHINO_DIR/src/api-server/node_modules" ]]; then
        echo -e "${YELLOW}Installing API server dependencies...${NC}"
        (cd "$RHINO_DIR/src/api-server" && npm install)
    fi

    RHINO_PORT="$port" RHINO_DIR="$RHINO_DIR" npx --prefix "$RHINO_DIR/src/api-server" tsx "$RHINO_DIR/src/api-server/index.ts"
}

cmd_init() {
    local project_dir="${1:-.}"
    cd "$project_dir"
    local project_name
    project_name=$(basename "$(pwd)")

    echo -e "${BOLD}=== rhino init: $project_name ===${NC}"
    echo ""

    # 1. Create directories
    echo -e "${BLUE}Creating .claude directories...${NC}"
    mkdir -p .claude/{plans,experiments,evals/reports}
    echo "  .claude/plans/"
    echo "  .claude/experiments/"
    echo "  .claude/evals/reports/"

    # 2. Find and link active plan (find any .md in plans/, use the most recent)
    local plan_count
    plan_count=$(find .claude/plans/ -name "*.md" 2>/dev/null | wc -l | tr -d ' ')
    if [[ "$plan_count" -gt 0 ]] && [[ ! -f ".claude/plans/active-plan.md" ]]; then
        local latest_plan
        latest_plan=$(ls -t .claude/plans/*.md 2>/dev/null | head -1)
        if [[ -n "$latest_plan" ]]; then
            ln -sf "$(basename "$latest_plan")" .claude/plans/active-plan.md
            echo -e "  ${GREEN}linked active-plan.md → $(basename "$latest_plan")${NC}"
        fi
    elif [[ -f ".claude/plans/active-plan.md" ]]; then
        echo -e "  ${DIM}active-plan.md already exists${NC}"
    else
        echo -e "  ${YELLOW}no plans found — run 'run strategy' to create one${NC}"
    fi

    # 3. Run baseline score
    echo ""
    echo -e "${BLUE}Running baseline score...${NC}"
    local baseline_score
    baseline_score=$("$RHINO_DIR/bin/score.sh" . --json 2>/dev/null || echo '{"score":0}')
    local score_num
    score_num=$(echo "$baseline_score" | grep -o '"score":[0-9]*' | grep -o '[0-9]*')
    echo -e "  ${BOLD}Baseline: ${score_num}/100${NC}"
    "$RHINO_DIR/bin/score.sh" . --breakdown 2>/dev/null | grep "^  " || true

    # Save baseline
    echo "$baseline_score" > .claude/experiments/baseline.json
    echo ""
    echo -e "  ${DIM}saved to .claude/experiments/baseline.json${NC}"

    # 4. Create core-loop test template if it doesn't exist
    if [[ ! -f ".claude/core-loop.spec.ts" ]] && [[ ! -f "e2e/core-loop.spec.ts" ]]; then
        echo ""
        echo -e "${BLUE}Creating core-loop test template...${NC}"
        mkdir -p e2e
        cat > e2e/core-loop.spec.ts << 'TESTEOF'
// Core Loop Test — Your val_bpb.
// This test verifies the product's core loop works end-to-end.
// Customize the steps below for YOUR product.
//
// Run: npx playwright test e2e/core-loop.spec.ts
// The experiment loop uses this as ground truth.

