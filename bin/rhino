#!/usr/bin/env bash
set -euo pipefail

# rhino — CLI for rhino-os v9
# A cofounder in your terminal. Measurement, agents, startup intelligence.

VERSION="9.4.0"
if [[ -n "${CLAUDE_PLUGIN_ROOT:-}" ]]; then
    RHINO_DIR="$CLAUDE_PLUGIN_ROOT"
else
    _RHINO_SOURCE="${BASH_SOURCE[0]}"
    while [[ -L "$_RHINO_SOURCE" ]]; do _RHINO_SOURCE="$(readlink "$_RHINO_SOURCE")"; done
    RHINO_DIR="$(cd "$(dirname "$_RHINO_SOURCE")/.." && pwd)"
fi

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# --- Config reader ---
source "$RHINO_DIR/bin/lib/config.sh"

# --- Dependency check (warn, don't block) ---
check_dep() {
    local cmd="$1" needed_for="$2"
    if ! command -v "$cmd" &>/dev/null; then
        echo -e "  ${YELLOW}⚠${NC} ${cmd} not found — needed for ${needed_for}" >&2
        return 1
    fi
    return 0
}

require_dep() {
    local cmd="$1" needed_for="$2"
    if ! command -v "$cmd" &>/dev/null; then
        echo -e "  ${RED}✗${NC} ${cmd} not found — required for ${needed_for}" >&2
        echo -e "  ${DIM}Install ${cmd} and try again.${NC}" >&2
        exit 1
    fi
}

# ============================================================
# SCORE
# ============================================================
cmd_score() {
    "$RHINO_DIR/bin/score.sh" "${@:-.}"
}

# ============================================================
# TASTE
# ============================================================
cmd_taste() {
    require_dep "node" "rhino taste"
    local args=("$@")
    if [[ ${#args[@]} -eq 0 ]]; then
        args=(".")
    fi
    local taste_script=""
    for _ts in "$RHINO_DIR"/lens/*/eval/taste.mjs; do
        [[ -f "$_ts" ]] && taste_script="$_ts" && break
    done
    [[ -z "$taste_script" ]] && taste_script="$RHINO_DIR/bin/taste.mjs"
    if [[ ! -f "$taste_script" ]]; then
        echo "taste.mjs not found — product lens not installed" >&2
        exit 1
    fi
    node "$taste_script" "${args[@]}"
}

# ============================================================
# STATUS
# ============================================================
cmd_status() {
    echo ""
    echo -e "  ${CYAN}◆${NC} ${BOLD}rhino-os${NC} ${DIM}v${VERSION}${NC}"
    echo ""

    # Claude CLI check
    if command -v claude &>/dev/null; then
        echo -e "  ${GREEN}✓${NC} Claude CLI"
    else
        echo -e "  ${RED}✗${NC} Claude CLI not found"
    fi

    # Mind files
    local mind_count=0
    for f in "$RHINO_DIR"/mind/*.md; do
        [[ -f "$f" ]] && ((mind_count++))
    done
    echo -e "  ${GREEN}✓${NC} Mind: ${mind_count} files loaded"

    # Measurement stack
    local stack_ok=true
    # Check measurement stack — taste.mjs searched across lenses
    local _taste_found=false
    for _ts in "$RHINO_DIR"/lens/*/eval/taste.mjs; do
        [[ -f "$_ts" ]] && _taste_found=true && break
    done
    for tool in "$RHINO_DIR/bin/score.sh" "$RHINO_DIR/bin/eval.sh"; do
        [[ ! -f "$tool" ]] && stack_ok=false
    done
    [[ "$_taste_found" == "false" ]] && stack_ok=false

    # Installed lenses
    local _lens_names=()
    for _lyml in "$RHINO_DIR"/lens/*/lens.yml; do
        [[ -f "$_lyml" ]] || continue
        local _lname
        _lname=$(grep '^name:' "$_lyml" 2>/dev/null | head -1 | sed 's/^name:[[:space:]]*//')
        [[ -n "$_lname" ]] && _lens_names+=("$_lname")
    done
    if [[ ${#_lens_names[@]} -gt 0 ]]; then
        echo -e "  ${GREEN}✓${NC} Lenses: ${_lens_names[*]}"
    fi

    if $stack_ok; then
        echo -e "  ${GREEN}✓${NC} Measurement: score, taste, eval"
    else
        echo -e "  ${RED}✗${NC} Measurement stack incomplete"
    fi

    # Last score
    if [[ -f ".claude/cache/score-cache.json" ]] && command -v jq &>/dev/null; then
        local score warnings mode a_count a_pass health_min
        score=$(jq -r '.score // "?"' .claude/cache/score-cache.json 2>/dev/null)
        mode=$(jq -r '.scoring_mode // "empty"' .claude/cache/score-cache.json 2>/dev/null)
        a_count=$(jq -r '.assertion_count // 0' .claude/cache/score-cache.json 2>/dev/null)
        a_pass=$(jq -r '.assertion_pass_count // 0' .claude/cache/score-cache.json 2>/dev/null)
        health_min=$(jq -r '.health_min // "?"' .claude/cache/score-cache.json 2>/dev/null)
        warnings=$(jq -r '.integrity_warnings // [] | join(", ")' .claude/cache/score-cache.json 2>/dev/null)
        echo ""
        if [[ "$mode" == "assertions" ]]; then
            echo -e "  ${DIM}score${NC}    ${BOLD}${score}/100${NC}  ${DIM}${a_pass}/${a_count} assertions · health ${health_min}${NC}"
        elif [[ "$mode" == "onboarding" ]]; then
            echo -e "  ${DIM}score${NC}    ${BOLD}${score}/50${NC}   ${DIM}onboarding · health ${health_min}${NC}"
        else
            echo -e "  ${DIM}score${NC}    ${BOLD}${score}/100${NC}  ${DIM}no value hypothesis · health ${health_min}${NC}"
        fi
        [[ -n "$warnings" ]] && echo -e "           ${YELLOW}⚠ ${warnings}${NC}"
    fi

    # Active plan (plan.yml)
    if [[ -f ".claude/plans/plan.yml" ]]; then
        local task_count=0 next_task=""
        task_count=$(grep -cE '^\s+-\s' .claude/plans/plan.yml 2>/dev/null || echo 0)
        next_task=$(grep -A1 'tasks:' .claude/plans/plan.yml 2>/dev/null | tail -1 | sed 's/^\s*- *//' | head -c 60 || echo "")
        if [[ -n "$next_task" ]]; then
            echo -e "  ${DIM}plan${NC}     ${task_count} tasks ${DIM}· ▸ ${next_task}${NC}"
        fi
    fi

    echo ""
}

# ============================================================
# CONFIG
# ============================================================
cmd_config() {
    echo ""
    echo -e "  ${CYAN}◆${NC} ${BOLD}rhino config${NC}"
    echo -e "  ${DIM}$RHINO_DIR/config/rhino.yml${NC}"
    echo ""

    if [[ ! -f "$RHINO_DIR/config/rhino.yml" ]]; then
        echo -e "  ${RED}✗${NC} rhino.yml not found"
        return 1
    fi

    echo -e "  ${BOLD}Scoring${NC}"
    printf "    cache         %ss\n" "$(cfg scoring.cache_ttl 300)"
    printf "    build gate    %s\n" "$(cfg scoring.build.gate_threshold 70)"
    printf "    health gate   %s\n" "$(cfg scoring.health_gate_threshold 20)"
    printf "    health warn   %s\n" "$(cfg scoring.health_warn_threshold 40)"
    printf "    onboard cap   %s\n" "$(cfg scoring.onboarding_cap 50)"
    echo ""
    echo -e "  ${BOLD}Taste${NC}"
    printf "    max routes    %s\n" "$(cfg taste.max_routes 8)"
    printf "    screenshots   %s\n" "$(cfg taste.max_screenshots 24)"
    printf "    cache         %ss\n" "$(cfg taste.cache_ttl 7200)"
    echo ""
    echo -e "  ${BOLD}Build${NC}"
    printf "    revert on reg %s\n" "$(cfg build.revert_on_regression true)"
    printf "    simplicity    %s\n" "$(cfg build.simplicity_bias true)"
    echo ""
    echo -e "  ${BOLD}Integrity${NC}"
    printf "    max delta     %s pts/commit\n" "$(cfg integrity.max_single_commit_delta 15)"
    printf "    plateau       %s tasks\n" "$(cfg integrity.plateau_tasks 3)"
    echo ""
}

# ============================================================
