{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp"]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "rhino-state": {
      "type": "stdio",
      "command": "npx",
      "args": ["tsx", "~/rhino-os/src/mcp-server/index.ts"]
    }
  }
}
