#!/usr/bin/env bash
set -euo pipefail

# rhino — CLI for rhino-os v6
# Measurement tools: score, taste, eval, status, config

VERSION="6.0.0"
_RHINO_SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$_RHINO_SOURCE" ]]; do
    _RHINO_SOURCE="$(readlink "$_RHINO_SOURCE")"
done
RHINO_DIR="$(cd "$(dirname "$_RHINO_SOURCE")/.." && pwd)"

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# --- Config reader ---
source "$RHINO_DIR/bin/lib/config.sh"

# ============================================================
# SCORE
# ============================================================
cmd_score() {
    "$RHINO_DIR/bin/score.sh" "${@:-.}"
}

# ============================================================
# TASTE
# ============================================================
cmd_taste() {
    local args=("$@")
    if [[ ${#args[@]} -eq 0 ]]; then
        args=(".")
    fi
    node "$RHINO_DIR/bin/taste.mjs" "${args[@]}"
}

# ============================================================
# STATUS
# ============================================================
cmd_status() {
    echo -e "${BOLD}rhino-os v${VERSION}${NC}"
    echo ""

    # Claude CLI check
    if command -v claude &>/dev/null; then
        echo -e "${GREEN}[OK]${NC} claude CLI"
    else
        echo -e "${RED}[FAIL]${NC} claude CLI not found"
    fi

    # Mind files
    local mind_count=0
    for f in "$RHINO_DIR"/mind/*.md; do
        [[ -f "$f" ]] && ((mind_count++))
    done
    echo -e "${GREEN}[OK]${NC} Mind: ${mind_count} files"

    # Last score
    if [[ -f ".claude/cache/score-cache.json" ]] && command -v jq &>/dev/null; then
        local score warnings
        score=$(jq -r '.total // "?"' .claude/cache/score-cache.json 2>/dev/null)
        warnings=$(jq -r '.integrity_warnings // [] | join(", ")' .claude/cache/score-cache.json 2>/dev/null)
        local msg="Score: $score"
        [[ -n "$warnings" ]] && msg="$msg  ${YELLOW}$warnings${NC}"
        echo -e "$msg"
    fi

    # Active plan
    if [[ -f ".claude/plans/active-plan.md" ]]; then
        local total done title
        title=$(head -5 .claude/plans/active-plan.md | grep -m1 '^#' | sed 's/^#* *//' || echo "")
        total=$(grep -c '^\- \[' .claude/plans/active-plan.md 2>/dev/null || echo 0)
        done=$(grep -c '^\- \[x\]' .claude/plans/active-plan.md 2>/dev/null || echo 0)
        echo ""
        echo -e "Sprint: ${BOLD}$title${NC} ($done/$total tasks)"
    fi

    echo ""
}

# ============================================================
# CONFIG
# ============================================================
cmd_config() {
    echo -e "${BOLD}=== rhino config ===${NC}"
    echo -e "${DIM}Source: $RHINO_DIR/config/rhino.yml${NC}"
    echo ""

    if [[ ! -f "$RHINO_DIR/config/rhino.yml" ]]; then
        echo -e "${RED}No rhino.yml found${NC}"
        return 1
    fi

    echo -e "${BOLD}Scoring:${NC}"
    printf "  cache: %ss  build gate: %s\n" \
        "$(cfg scoring.cache_ttl 300)" \
        "$(cfg scoring.build.gate_threshold 70)"

    echo -e "${BOLD}Taste:${NC}"
    printf "  routes: %s  screenshots: %s  cache: %ss\n" \
        "$(cfg taste.max_routes 8)" \
        "$(cfg taste.max_screenshots 24)" \
        "$(cfg taste.cache_ttl 7200)"

    echo -e "${BOLD}Experiments:${NC}"
    printf "  moonshot: every %s  max files: %s\n" \
        "$(cfg experiments.moonshot_every_n 5)" \
        "$(cfg experiments.max_files_per_experiment 5)"

    echo -e "${BOLD}Integrity:${NC}"
    printf "  max delta: %s  plateau: %s exps\n" \
        "$(cfg integrity.max_single_commit_delta 15)" \
        "$(cfg integrity.plateau_experiments 5)"
}

# ============================================================
# EVAL
# ============================================================
cmd_eval() {
    local eval_script="$RHINO_DIR/bin/eval.sh"
    if [[ ! -f "$eval_script" ]]; then
        echo -e "${RED}eval.sh not found at $eval_script${NC}"
        exit 1
    fi
    bash "$eval_script" "${@:-.}"
}

# ============================================================
# HELP
# ============================================================
cmd_help() {
    echo -e "${BOLD}rhino${NC} v${VERSION} — eyes, not rails"
    echo ""
    echo -e "${BOLD}Usage:${NC} rhino <command> [args...]"
    echo ""
    echo -e "${BOLD}Measure:${NC}"
    echo "  score [dir]        Structural lint score"
    echo "  taste [dir]        Visual product eval (Claude Vision)"
    echo "  eval [dir]         Run belief evals"
    echo ""
    echo -e "${BOLD}System:${NC}"
    echo "  status             Health overview"
    echo "  config             Show configuration"
    echo "  install [--check]  Install/update rhino-os"
    echo ""
    echo -e "${BOLD}Config:${NC} $RHINO_DIR/config/rhino.yml"
}

# ============================================================
# MAIN
# ============================================================
case "${1:-help}" in
    score)      shift; cmd_score "$@" ;;
    taste)      shift; cmd_taste "$@" ;;
    eval)       shift; cmd_eval "$@" ;;
    status)     cmd_status ;;
    config)     cmd_config ;;
    install)    shift; bash "$RHINO_DIR/install.sh" "$@" ;;
    help|--help|-h) cmd_help ;;
    version|--version|-v) echo "rhino v${VERSION}" ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        echo "Run 'rhino help' for available commands."
        exit 1
        ;;
esac
