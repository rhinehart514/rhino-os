# ============================================================
# MAIN
# ============================================================
case "${1:-help}" in
    score)      shift; cmd_score "$@" ;;
    taste)      shift; cmd_taste "$@" ;;
    eval)       shift; cmd_eval "$@" ;;
    bench)      shift; cmd_bench "$@" ;;
    data)       shift; cmd_data "$@" ;;
    plan)       shift; cmd_plan "$@" ;;
    todo)       shift; cmd_todo "$@" ;;
    go)         shift; cmd_go "$@" ;;
    feature|feat) shift; cmd_feature "$@" ;;
    self)       shift; cmd_self "$@" ;;
    test)       shift; cmd_test "$@" ;;
    status)     cmd_status ;;
    config)     cmd_config ;;
    skill)      shift; bash "$RHINO_DIR/bin/skill.sh" "$@" ;;
    serve)      shift; require_dep "node" "rhino serve"; node "$RHINO_DIR/bin/serve.mjs" "$@" ;;
    init)       shift; bash "$RHINO_DIR/bin/init.sh" "$@" ;;
    trail)      shift; bash "$RHINO_DIR/bin/trail.sh" "$@" ;;
    update)     cmd_update ;;
    doctor)     cmd_doctor ;;
    install)    shift; bash "$RHINO_DIR/install.sh" "$@" ;;
    uninstall)  shift; bash "$RHINO_DIR/uninstall.sh" "$@" ;;
    help|--help|-h) cmd_help ;;
    version|--version|-v) echo "rhino v${VERSION}" ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        echo "Run 'rhino help' for available commands."
        exit 1
        ;;
esac
